#ifndef SEXPR_FILE_VERSIONS_H
#define SEXPR_FILE_VERSIONS_H

// Generated at configure time from the authoritative format-version ledgers
// (pcbnew/pcb_io/kicad_sexpr/pcb_io_kicad_sexpr.h and eeschema/sch_file_versions.h)
// so standalone tools that cannot link pcbnew/eeschema still emit the current versions.
// Do not edit; bump the versions in those ledgers instead.

#define SEXPR_FOOTPRINT_FILE_VERSION   @SEXPR_BOARD_FILE_VERSION@
#define SEXPR_SYMBOL_LIB_FILE_VERSION  @SEXPR_SYMBOL_LIB_FILE_VERSION@

#endif // SEXPR_FILE_VERSIONS_H
