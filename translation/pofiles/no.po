#, c-format
msgid "<package> '%s' duplicated in <library> '%s'"
msgstr "<package> '%s' duplisert i <library> '%s'"

#: pcbnew/pcb_io/eagle/pcb_io_eagle.cpp:1300
#, c-format
msgid "No '%s' package in library '%s'."
msgstr "Ingen '%s'-pakke i bibliotek '%s'."

#: pcbnew/pcb_io/eagle/pcb_io_eagle.cpp:1533
#: pcbnew/pcb_io/eagle/pcb_io_eagle.cpp:2353
#, c-format
msgid "Ignoring a polygon since Eagle layer '%s' (%d) was not mapped"
msgstr "Ignorerer en polygon siden Eagle-laget «%s' (%d) ikke ble kartlagt"

#: pcbnew/pcb_io/eagle/pcb_io_eagle.cpp:1610
#, c-format
msgid "Skipping a polygon on layer '%s' (%d): outline count is not 1"
msgstr "Hopper over en polygon på lag '%s' (%d): antall omriss er ikke 1"

#: pcbnew/pcb_io/eagle/pcb_io_eagle.cpp:1918
#, c-format
msgid "Ignoring a wire since Eagle layer '%s' (%d) was not mapped"
msgstr "Ignorerer en ledning siden Eagle-laget «%s' (%d) ikke ble kartlagt"

#: pcbnew/pcb_io/eagle/pcb_io_eagle.cpp:2086
#: pcbnew/pcb_io/eagle/pcb_io_eagle.cpp:2088
#: pcbnew/pcb_io/fabmaster/import_fabmaster.cpp:2843
#: pcbnew/pcb_io/geda/pcb_io_geda.cpp:592
#: pcbnew/pcb_io/kicad_legacy/pcb_io_kicad_legacy.cpp:1592
#, c-format
msgid ""
"Invalid zero-sized pad ignored in\n"
"file: %s"
msgstr ""
"Ugyldig pad med null størrelse ignorert i\n"
"fil: %s"

#: pcbnew/pcb_io/eagle/pcb_io_eagle.cpp:2100
