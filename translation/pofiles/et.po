msgstr "Tekstimuutujaid ei saanud seada, kuna projekti pole lisatud."

#: eeschema/sch_io/cadstar/cadstar_sch_archive_loader.cpp:2123
#, c-format
msgid ""
"Symbol '%s' is rotated by an angle of %.1f degrees in the original CADSTAR "
