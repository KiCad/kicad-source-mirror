"        <td>&nbsp;<br><samp>J1B</samp> (when ROW=0, pin 2 in unit B)</td>\n"
"    </tr>\n"
"    <tr>\n"
"        <td>&nbsp;<br><samp>${J1:NET_NAME(${COL})}</samp></td>\n"
"        <td></td>\n"
