#: eeschema/sim/kibis/kibis.cpp:1118
msgid "Model has only one waveform pair, reduced accuracy"
msgstr "ໂມເດລມີຄູ່ຮູບຄື້ນພຽງຄູ່ດຽວ, ຄວາມແມ່ນຍຳຫຼຸດລົງ"

#: eeschema/sim/kibis/kibis.cpp:1138 eeschema/sim/kibis/kibis.cpp:1344
msgid "Driver needs at least a pullup or a pulldown"
msgstr "ໄດຣເວີຕ້ອງການຢ່າງໜ້ອຍ pullup ຫຼື pulldown"

#: eeschema/sim/kibis/kibis.cpp:1327 eeschema/sim/kibis/kibis.cpp:1336
msgid ""
"There are two waveform pairs, but only one transistor. More equations than "
"unknowns."
msgstr "ມີຄູ່ຮູບຄື້ນສອງຄູ່, ແຕ່ມີທຣານຊິດເຕີພຽງຕົວດຽວ. ສົມຜົນຫຼາຍກວ່າຕົວປ່ຽນທີ່ບໍ່ຮູ້ຄ່າ."

#: eeschema/sim/kibis/kibis.cpp:1435
msgid "Model has no waveform pair, using [Ramp] instead, poor accuracy"
msgstr "ໂມເດລບໍ່ມີຄູ່ຮູບຄື້ນ, ຈະໃຊ້ [Ramp] ແທນ, ຄວາມແມ່ນຍຳຕ່ຳ"

#: eeschema/sim/kibis/kibis.cpp:1449
msgid "Model has more than 2 waveform pairs, using the first two."
msgstr "ໂມເດລມີຄູ່ຮູບຄື້ນຫຼາຍກວ່າ 2 ຄູ່, ຈະໃຊ້ສອງຄູ່ທຳອິດ."

#: eeschema/sim/kibis/kibis.cpp:1492
msgid "Series and Series_switch models are passive devices, not drivers."
msgstr "ໂມເດລ Series ແລະ Series_switch ແມ່ນອຸປະກອນແພດຊີບ (passive), ບໍ່ແມ່ນໄດຣເວີ."

#: eeschema/sim/kibis/kibis.cpp:1497
msgid "Invalid model type for a driver."
msgstr "ປະເພດໂມເດລບໍ່ຖືກຕ້ອງສຳລັບໄດຣເວີ."

#: eeschema/sim/kibis/kibis.cpp:1554
msgid "Series model has no [Series Pin Mapping] partner pin."
msgstr "ໂມເດລ Series ບໍ່ມີຂາຄູ່ຮ່ວມ [Series Pin Mapping]."

#: eeschema/sim/kibis/kibis.cpp:1606
msgid "Invalid model type for a device"
