msgstr "ອັບເກຣດຄັງຟຸດປຣິນໃຫ້ເປັນຮູບແບບເວີຊັນ KiCad ປັດຈຸບັນ"

#: kicad/cli/command_fp_upgrade.cpp:41
msgid "Forces the footprint library to be resaved regardless of versioning"
msgstr "ບັງຄັບໃຫ້ບັນທຶກຄັງຟຸດປຣິນໃໝ່ໂດຍບໍ່ສົນໃຈເວີຊັນ"

#: kicad/cli/command_gerber.h:33
msgid ""
"View and compare existing Gerber/Excellon files. To export Gerbers from a "
"PCB, use 'pcb export gerbers'"
msgstr ""
"ເບິ່ງ ແລະ ປຽບທຽບໄຟລ໌ Gerber/Excellon ທີ່ມີຢູ່. ເພື່ອສົ່ງອອກ Gerber ຈາກ PCB, ໃຫ້ໃຊ້ 'pcb "
"export gerbers'"

#: kicad/cli/command_gerber_convert.h:33
msgid "Convert Gerber/Excellon to other formats"
msgstr "ແປງໄຟລ໌ Gerber/Excellon ເປັນຮູບແບບອື່ນ"

#: kicad/cli/command_gerber_convert_png.cpp:50
msgid "Convert a Gerber or Excellon file to PNG image"
msgstr "ແປງໄຟລ໌ Gerber ຫຼື Excellon ເປັນຮູບພາບ PNG"

#: kicad/cli/command_gerber_convert_png.cpp:55
msgid "Resolution in DPI (default: 300)"
msgstr "ຄວາມລະອຽດເປັນ DPI (ເລີ່ມຕົ້ນ: 300)"

#: kicad/cli/command_gerber_convert_png.cpp:61
msgid "Output width in pixels (overrides DPI)"
msgstr "ຄວາມກວ້າງສົ່ງອອກເປັນພິກເຊວ (ຂຽນທັບ DPI)"

#: kicad/cli/command_gerber_convert_png.cpp:67
msgid "Output height in pixels (overrides DPI)"
msgstr "ຄວາມສູງສົ່ງອອກເປັນພິກເຊວ (ຂຽນທັບ DPI)"

#: kicad/cli/command_gerber_convert_png.cpp:73
msgid "Use transparent background (default)"
msgstr "ໃຊ້ພື້ນຫຼັງໂປ່ງໃສ (ເລີ່ມຕົ້ນ)"

#: kicad/cli/command_gerber_convert_png.cpp:76
#: kicad/cli/command_gerber_diff.cpp:86 kicad/cli/command_gerber_info.cpp:56
msgid "Fail on any parse warnings or errors"
msgstr "ໃຫ້ຢຸດທັນທີຫາກພົບຄຳເຕືອນ ຫຼື ຂໍ້ຜິດພາດໃນການວິເຄາະ"

#: kicad/cli/command_gerber_convert_png.cpp:80
msgid "Units for viewport parameters, options: mm, inch, mils (default: mm)"
msgstr "ຫົວໜ່ວຍສຳລັບພາລາມິເຕີ viewport, ຕົວເລືອກ: mm, inch, mils (ເລີ່ມຕົ້ນ: mm)"

#: kicad/cli/command_gerber_convert_png.cpp:86
msgid "Viewport origin X"
msgstr "ຈຸດເລີ່ມຕົ້ນ Viewport X"

#: kicad/cli/command_gerber_convert_png.cpp:92
msgid "Viewport origin Y"
msgstr "ຈຸດເລີ່ມຕົ້ນ Viewport Y"

#: kicad/cli/command_gerber_convert_png.cpp:98
msgid "Viewport width (enables viewport mode)"
msgstr "ຄວາມກວ້າງ Viewport (ເປີດໃຊ້ໂໝດ viewport)"

#: kicad/cli/command_gerber_convert_png.cpp:104
msgid "Viewport height (enables viewport mode)"
msgstr "ຄວາມສູງ Viewport (ເປີດໃຊ້ໂໝດ viewport)"

#: kicad/cli/command_gerber_convert_png.cpp:109
msgid "Foreground color as hex (e.g., '#FFFFFF')"
msgstr "ສີພື້ນໜ້າໃນຮູບແບບ hex (ເຊັ່ນ: '#FFFFFF')"

#: kicad/cli/command_gerber_convert_png.cpp:114
msgid "Background color as hex (e.g., '#000000')"
msgstr "ສີພື້ນຫຼັງໃນຮູບແບບ hex (ເຊັ່ນ: '#000000')"

#: kicad/cli/command_gerber_convert_png.cpp:147
#: kicad/cli/command_gerber_info.cpp:100
#, c-format
msgid "Invalid units: %s\n"
msgstr "ຫົວໜ່ວຍບໍ່ຖືກຕ້ອງ: %s\n"

#: kicad/cli/command_gerber_convert_png.cpp:158
msgid ""
"Error: both --window-width and --window-height must be specified together\n"
msgstr "ຂໍ້ຜິດພາດ: ຕ້ອງລະບຸທັງ --window-width ແລະ --window-height ພ້ອມກັນ\n"

#: kicad/cli/command_gerber_diff.cpp:47
msgid "Compare two Gerber or Excellon files and show differences"
msgstr "ປຽບທຽບໄຟລ໌ Gerber ຫຼື Excellon ສອງໄຟລ໌ ແລະ ສະແດງຄວາມແຕກຕ່າງ"

#: kicad/cli/command_gerber_diff.cpp:50
msgid "Reference file (first Gerber/Excellon file)"
msgstr "ໄຟລ໌ອ້າງອີງ (ໄຟລ໌ Gerber/Excellon ທຳອິດ)"

#: kicad/cli/command_gerber_diff.cpp:54
msgid "Comparison file (second Gerber/Excellon file)"
msgstr "ໄຟລ໌ປຽບທຽບ (ໄຟລ໌ Gerber/Excellon ທີສອງ)"

#: kicad/cli/command_gerber_diff.cpp:59
msgid "Output format: png, text, or json (default: png)"
msgstr "ຮູບແບບສົ່ງອອກ: png, text, ຫຼື json (ເລີ່ມຕົ້ນ: png)"

#: kicad/cli/command_gerber_diff.cpp:65
msgid "Resolution in DPI for PNG output (default: 300)"
msgstr "ຄວາມລະອຽດເປັນ DPI ສຳລັບການສົ່ງອອກ PNG (ເລີ່ມຕົ້ນ: 300)"

#: kicad/cli/command_gerber_diff.cpp:69
msgid "Disable anti-aliasing for PNG output"
msgstr "ປິດການລົບຮອຍຢັກ (anti-aliasing) ສຳລັບການສົ່ງອອກ PNG"

#: kicad/cli/command_gerber_diff.cpp:73
msgid "Use transparent background for PNG output"
msgstr "ໃຊ້ພື້ນຫຼັງໂປ່ງໃສສຳລັບການສົ່ງອອກ PNG"

#: kicad/cli/command_gerber_diff.cpp:77
msgid "Only set exit code (0=identical, 1=different), no output"
msgstr "ຕັ້ງຄ່າສະເພາະລະຫັດການອອກ (0=ຄືກັນ, 1=ຕ່າງກັນ), ບໍ່ມີການສົ່ງອອກ"

#: kicad/cli/command_gerber_diff.cpp:83
msgid "Tolerance in nm for floating point comparisons (default: 0)"
msgstr "ຄ່າຄວາມຄາດເຄື່ອນເປັນ nm ສຳລັບການປຽບທຽບເລກທົດສະນິຍົມ (ເລີ່ມຕົ້ນ: 0)"

#: kicad/cli/command_gerber_diff.cpp:89
msgid ""
"Skip bounding-box origin alignment; catches absolute-placement regressions"
msgstr ""
"ຂ້າມການຈັດວາງຈຸດເລີ່ມຕົ້ນຂອງຂອບເຂດ (bounding-box); ເພື່ອກວດສອບການປ່ຽນແປງຕຳແໜ່ງສຳບູນ"

#: kicad/cli/command_gerber_diff.cpp:124 kicad/cli/command_gerber_info.cpp:80
#, c-format
msgid "Invalid output format: %s\n"
msgstr "ຮູບແບບສົ່ງອອກບໍ່ຖືກຕ້ອງ: %s\n"

#: kicad/cli/command_gerber_info.cpp:40
msgid "Display information about a Gerber or Excellon file"
msgstr "ສະແດງຂໍ້ມູນກ່ຽວກັບໄຟລ໌ Gerber ຫຼື Excellon"

#: kicad/cli/command_gerber_info.cpp:44
msgid "Output format, options: text, json"
msgstr "ຮູບແບບສົ່ງອອກ, ຕົວເລືອກ: text, json"

#: kicad/cli/command_gerber_info.cpp:49
msgid "Output units, options: mm, inch, mils (default: mm)"
msgstr "ຫົວໜ່ວຍສົ່ງອອກ, ຕົວເລືອກ: mm, inch, mils (ເລີ່ມຕົ້ນ: mm)"

#: kicad/cli/command_gerber_info.cpp:53
msgid "Calculate and display copper area"
msgstr "ຄິດໄລ່ ແລະ ສະແດງພື້ນທີ່ທອງແດງ"

#: kicad/cli/command_git_mergedriver.cpp:52
msgid ""
"Internal git merge-driver hook (configured automatically by KiCad's git "
"integration; not intended for direct use)."
msgstr ""
"Internal git merge-driver hook (ຖືກກຳນົດຄ່າອັດຕະໂນມັດໂດຍ KiCad's git integration; "
"ບໍ່ໄດ້ມີໄວ້ສຳລັບໃຊ້ໂດຍກົງ)."

#: kicad/cli/command_git_mergedriver.cpp:57
msgid "Document kind: pcb, sch, sym, or fp"
msgstr "ປະເພດເອກະສານ: pcb, sch, sym, ຫຼື fp"

#: kicad/cli/command_git_mergedriver.cpp:105
#, c-format
msgid "Unknown --kind '%s' (expected pcb, sch, sym, or fp)\n"
msgstr "ບໍ່ຮູ້ຈັກ --kind '%s' (ຕ້ອງການ pcb, sch, sym, ຫຼື fp)\n"

#: kicad/cli/command_git_mergedriver.cpp:121
msgid "Could not create a temporary directory for the merge.\n"
msgstr "ບໍ່ສາມາດສ້າງໂຟນເດີຊົ່ວຄາວສຳລັບການລວມໄຟລ໌ (merge).\n"

#: kicad/cli/command_git_mergedriver.cpp:141
msgid "Could not stage merge inputs.\n"
msgstr "ບໍ່ສາມາດຈັດຕຽມ (stage) ຂໍ້ມູນນຳເຂົ້າສຳລັບການລວມໄຟລ໌.\n"

#: kicad/cli/command_git_mergedriver.cpp:160
msgid "Could not write merged output.\n"
msgstr "ບໍ່ສາມາດຂຽນຜົນການລວມໄຟລ໌ໄດ້.\n"

#: kicad/cli/command_import.cpp:47
msgid "Import non-KiCad board and/or schematic files into a new KiCad project"
msgstr "ນຳເຂົ້າໄຟລ໌ແຜ່ນວົງຈອນ ແລະ/ຫຼື ຜັງວົງຈອນທີ່ບໍ່ແມ່ນ KiCad ເຂົ້າໃນໂຄງການ KiCad ໃໝ່"

#: kicad/cli/command_import.cpp:50
msgid "Input file(s) to import; each is autodetected as a board or schematic"
msgstr "ໄຟລ໌ນຳເຂົ້າທີ່ຈະນຳເຂົ້າ; ແຕ່ລະໄຟລ໌ຈະຖືກກວດສອບອັດຕະໂນມັດວ່າເປັນແຜ່ນວົງຈອນ ຫຼື ຜັງວົງຈອນ"

#: kicad/cli/command_import.cpp:57
msgid ""
"Output project path stem; produces <stem>.kicad_pro plus the imported <stem>."
"kicad_pcb and/or <stem>.kicad_sch beside it. Defaults to the first input's "
"name in the current directory."
msgstr ""
"ຊື່ຫຼັກຂອງເສັ້ນທາງໂຄງການສົ່ງອອກ; ຈະສ້າງ <stem>.kicad_pro ພ້ອມກັບ <stem>.kicad_pcb ແລະ/ຫຼື "
"<stem>.kicad_sch ທີ່ນຳເຂົ້າໄວ້ຂ້າງກັນ. ຄ່າເລີ່ມຕົ້ນແມ່ນຊື່ຂອງໄຟລ໌ນຳເຂົ້າທຳອິດໃນໂຟນເດີປັດຈຸບັນ."

#: kicad/cli/command_import.cpp:64
msgid ""
"JSON file mapping source layer names to KiCad layer names for imported "
"boards; unmapped layers use the automatic best-guess"
msgstr ""
"ໄຟລ໌ JSON ທີ່ຈັບຄູ່ຊື່ຊັ້ນແຫຼ່ງທີ່ມາກັບຊື່ຊັ້ນ KiCad ສຳລັບແຜ່ນວົງຈອນທີ່ນຳເຂົ້າ; "
"ຊັ້ນທີ່ບໍ່ໄດ້ຈັບຄູ່ຈະຖືກຄາດເດົາໃຫ້ດີທີ່ສຸດໂດຍອັດຕະໂນມັດ"

#: kicad/cli/command_import.cpp:77
msgid "At least one input file is required\n"
msgstr "ຕ້ອງການໄຟລ໌ນຳເຂົ້າຢ່າງໜ້ອຍໜຶ່ງໄຟລ໌\n"

#: kicad/cli/command_import.cpp:119
#, c-format
msgid "Could not create output directory: %s\n"
msgstr "ບໍ່ສາມາດສ້າງໂຟນເດີສົ່ງອອກ: %s\n"

#: kicad/cli/command_import.cpp:139
#, c-format
msgid "Could not create project: %s\n"
msgstr "ບໍ່ສາມາດສ້າງໂຄງການ: %s\n"

#: kicad/cli/command_import.cpp:199
#, c-format
msgid ""
"Could not import '%s': a board and a schematic have already been imported "
"for this project\n"
msgstr "ບໍ່ສາມາດນຳເຂົ້າ '%s': ແຜ່ນວົງຈອນ ແລະ ຜັງວົງຈອນໄດ້ຖືກນຳເຂົ້າແລ້ວສຳລັບໂຄງການນີ້\n"

#: kicad/cli/command_import.cpp:204
#, c-format
msgid "No board or schematic importer recognizes the file: %s\n"
msgstr "ບໍ່ມີຕົວນຳເຂົ້າແຜ່ນວົງຈອນ ຫຼື ຜັງວົງຈອນໃດທີ່ຮູ້ຈັກໄຟລ໌: %s\n"

#: kicad/cli/command_import.cpp:214
msgid "No inputs could be imported\n"
msgstr "ບໍ່ສາມາດນຳເຂົ້າຂໍ້ມູນໃດໆໄດ້\n"

#: kicad/cli/command_import.cpp:230
#, c-format
msgid "Created project '%s'\n"
msgstr "ສ້າງໂຄງການ '%s' ສຳເລັດ\n"

#: kicad/cli/command_import.cpp:236
#, c-format
msgid "Failed to write project file: %s\n"
msgstr "ຂຽນໄຟລ໌ໂຄງການບໍ່ສຳເລັດ: %s\n"

#: kicad/cli/command_jobset.h:32
msgid "Jobset"
msgstr "ຊຸດວຽກ (Jobset)"

#: kicad/cli/command_jobset_run.cpp:46
msgid "Runs a jobset file"
msgstr "ເຮັດວຽກໄຟລ໌ຊຸດວຽກ (jobset)"

#: kicad/cli/command_jobset_run.cpp:50
msgid ""
"Stops processing jobs as they are executed sequentially on the first failure "
"of a job"
msgstr "ຢຸດການປະມວນຜົນວຽກຕາມລຳດັບທັນທີເມື່ອມີວຽກໃດໜຶ່ງລົ້ມເຫຼວ"

#: kicad/cli/command_jobset_run.cpp:54
msgid "Jobset file to be run"
msgstr "ໄຟລ໌ຊຸດວຽກທີ່ຕ້ອງການເຮັດວຽກ"

#: kicad/cli/command_jobset_run.cpp:59
msgid ""
"Jobset file output to generate, leave blank for all outputs defined in the "
"jobset"
msgstr "ຜົນສົ່ງອອກຂອງໄຟລ໌ຊຸດວຽກທີ່ຕ້ອງການສ້າງ, ປະຫວ່າງໄວ້ເພື່ອສ້າງທຸກຜົນສົ່ງອອກທີ່ກຳນົດໃນຊຸດວຽກ"

#: kicad/cli/command_mergetool.cpp:82
msgid ""
"Three-way merge driver for `git mergetool`. Detects PCB vs schematic vs "
"library item from the output extension, opens the resolution dialog in the "
"GUI kicad binary for any unresolved conflicts where available, and writes "
"the merged file."
msgstr ""
"Three-way merge driver ສຳລັບ `git mergetool`. ກວດສອບ PCB, ຜັງວົງຈອນ ຫຼື "
"ລາຍການຄັງອຸປະກອນຈາກນາມສະກຸນໄຟລ໌ສົ່ງອອກ, ເປີດປ່ອງຢ້ຽມແກ້ໄຂຂໍ້ຂັດແຍ່ງໃນ GUI KiCad ຖ້າມີ, ແລະ "
"ຂຽນໄຟລ໌ທີ່ລວມແລ້ວ."

#: kicad/cli/command_mergetool.cpp:89
msgid ""
"Common-ancestor file (.kicad_pcb, .kicad_sch, .kicad_sym, or .kicad_mod)"
msgstr ""
"ໄຟລ໌ບັນພະບຸລຸດຮ່ວມ (Common-ancestor) (.kicad_pcb, .kicad_sch, .kicad_sym, ຫຼື ."
"kicad_mod)"

#: kicad/cli/command_mergetool.cpp:94
msgid "'Ours' file"
msgstr "ໄຟລ໌ຝ່າຍເຮົາ ('Ours')"

#: kicad/cli/command_mergetool.cpp:98
msgid "'Theirs' file"
msgstr "ໄຟລ໌ຝ່າຍເຂົາ ('Theirs')"

#: kicad/cli/command_mergetool.cpp:103
msgid "Output path; extension picks the document type"
msgstr "ເສັ້ນທາງສົ່ງອອກ; ນາມສະກຸນໄຟລ໌ຈະເປັນຕົວເລືອກປະເພດເອກະສານ"

#: kicad/cli/command_mergetool.cpp:126
#, c-format
msgid ""
"Unsupported output extension '%s'. Expected .kicad_pcb, .kicad_sch, ."
"kicad_sym, or .kicad_mod\n"
msgstr ""
"ບໍ່ຮອງຮັບນາມສະກຸນສົ່ງອອກ '%s'. ຕ້ອງການ .kicad_pcb, .kicad_sch, .kicad_sym, ຫຼື ."
"kicad_mod\n"

#: kicad/cli/command_mergetool.cpp:141
msgid "Cannot find the main kicad binary alongside kicad-cli.\n"
msgstr "ບໍ່ພົບໄຟລ໌ KiCad ຫຼັກ (binary) ຢູ່ຂ້າງໆ kicad-cli.\n"

#: kicad/cli/command_mergetool.cpp:166
#, c-format
msgid "Failed to launch '%s'\n"
msgstr "ເລີ່ມຕົ້ນ '%s' ບໍ່ສຳເລັດ\n"

#: kicad/cli/command_pcb_diff.cpp:28
msgid "Diff two .kicad_pcb files and emit JSON, text, PNG, or SVG"
msgstr "ປຽບທຽບຄວາມແຕກຕ່າງສອງໄຟລ໌ .kicad_pcb ແລະ ສົ່ງອອກເປັນ JSON, text, PNG, ຫຼື SVG"

#: kicad/cli/command_pcb_diff.cpp:29
msgid "Reference PCB file"
msgstr "ໄຟລ໌ PCB ອ້າງອີງ"

#: kicad/cli/command_pcb_diff.cpp:30
msgid "Comparison PCB file"
msgstr "ໄຟລ໌ PCB ທີ່ໃຊ້ປຽບທຽບ"

#: kicad/cli/command_pcb_drc.cpp:49
msgid "Runs the Design Rules Check (DRC) on the PCB and creates a report"
msgstr "ກວດສອບກົດການອອກແບບ (DRC) ໃນ PCB ແລະ ສ້າງລາຍງານ"

#: kicad/cli/command_pcb_drc.cpp:54 kicad/cli/command_pcb_export_stats.cpp:40
#: kicad/cli/command_sch_erc.cpp:50
msgid "Output file format, options: json, report"
msgstr "ຮູບແບບໄຟລ໌ສົ່ງອອກ, ຕົວເລືອກ: json, report"

#: kicad/cli/command_pcb_drc.cpp:67 kicad/cli/command_sch_erc.cpp:55
msgid "Report units; valid options: in, mm, mils"
msgstr "ຫົວໜ່ວຍລາຍງານ; ຕົວເລືອກ: in, mm, mils"

#: kicad/cli/command_pcb_drc.cpp:71
msgid ""
"Report all DRC violations, this is equivalent to including all the other "
"severity arguments"
msgstr "ລາຍງານການລະເມີດ DRC ທັງໝົດ, ເຊິ່ງເທົ່າກັບການລວມເອົາທຸກລະດັບຄວາມຮ້າຍແຮງອື່ນໆ"

#: kicad/cli/command_pcb_drc.cpp:76
msgid ""
"Report all DRC error level violations, this can be combined with the other "
"severity arguments"
msgstr ""
"ລາຍງານການລະເມີດ DRC ທັງໝົດໃນລະດັບຂໍ້ຜິດພາດ (Error), ສາມາດໃຊ້ຮ່ວມກັບລະດັບຄວາມຮ້າຍແຮງອື່ນໄດ້"

#: kicad/cli/command_pcb_drc.cpp:81
msgid ""
"Report all DRC warning level violations, this can be combined with the other "
"severity arguments"
msgstr ""
"ລາຍງານການລະເມີດ DRC ທັງໝົດໃນລະດັບຄຳເຕືອນ (Warning), ສາມາດໃຊ້ຮ່ວມກັບລະດັບຄວາມຮ້າຍແຮງອື່ນໄດ້"

#: kicad/cli/command_pcb_drc.cpp:86
msgid ""
"Report all excluded DRC violations, this can be combined with the other "
"severity arguments"
msgstr "ລາຍງານການລະເມີດ DRC ທັງໝົດທີ່ຖືກຍົກເວັ້ນ, ສາມາດໃຊ້ຮ່ວມກັບລະດັບຄວາມຮ້າຍແຮງອື່ນໄດ້"

#: kicad/cli/command_pcb_drc.cpp:91
msgid "Return a nonzero exit code if DRC violations exist"
msgstr "ສົ່ງຄືນລະຫັດການອອກທີ່ບໍ່ແມ່ນສູນ ຫາກພົບການລະເມີດ DRC"

#: kicad/cli/command_pcb_drc.cpp:95
msgid "Refill zones before running DRC"
msgstr "ຕື່ມຂໍ້ມູນພື້ນທີ່ (Refill zones) ກ່ອນກວດສອບ DRC"

#: kicad/cli/command_pcb_drc.cpp:99
msgid "Save the board after DRC, must be used with --refill-zones"
msgstr "ບັນທຶກແຜ່ນວົງຈອນຫຼັງຈາກ DRC, ຕ້ອງໃຊ້ຮ່ວມກັບ --refill-zones"

#: kicad/cli/command_pcb_drc.cpp:156 kicad/cli/command_pcb_export_3d.cpp:309
#: kicad/cli/command_pcb_export_drill.cpp:166
#: kicad/cli/command_pcb_export_dxf.cpp:175
#: kicad/cli/command_pcb_export_pos.cpp:150
#: kicad/cli/command_pcb_export_stats.cpp:98 kicad/cli/command_sch_erc.cpp:132
msgid "Invalid units specified\n"
msgstr "ຫົວໜ່ວຍທີ່ລະບຸບໍ່ຖືກຕ້ອງ\n"

#: kicad/cli/command_pcb_drc.cpp:171 kicad/cli/command_pcb_export_stats.cpp:86
#: kicad/cli/command_sch_erc.cpp:148
msgid "Invalid report format\n"
msgstr "ຮູບແບບລາຍງານບໍ່ຖືກຕ້ອງ\n"

#: kicad/cli/command_pcb_export.h:33
msgid "Export utilities (Gerbers, drill, position files, etc)"
msgstr "ເຄື່ອງມືສົ່ງອອກ (Gerber, ໄຟລ໌ເຈາະ, ໄຟລ໌ຕຳແໜ່ງ, ແລະ ອື່ນໆ)"

#: kicad/cli/command_pcb_export_3d.cpp:79
msgid ""
"Output file format, options: step, stepz, brep, xao, glb (binary glTF), ply, "
"stl"
msgstr ""
"ຮູບແບບໄຟລ໌ສົ່ງອອກ, ຕົວເລືອກ: step, stepz, brep, xao, glb (binary glTF), ply, stl"

#: kicad/cli/command_pcb_export_3d.cpp:84
msgid "Overwrite output file"
msgstr "ຂຽນທັບໄຟລ໌ສົ່ງອອກ"

#: kicad/cli/command_pcb_export_3d.cpp:88
msgid "Exclude 3D models for components with 'Unspecified' footprint type"
msgstr "ບໍ່ລວມແບບຈຳລອງ 3D ສຳລັບອຸປະກອນທີ່ມີປະເພດຟຸດປຣິນເປັນ 'ບໍ່ໄດ້ກຳນົດ' (Unspecified)"

#: kicad/cli/command_pcb_export_3d.cpp:93
msgid "Exclude 3D models for components with 'Do not populate' attribute"
msgstr "ບໍ່ລວມແບບຈຳລອງ 3D ສຳລັບອຸປະກອນທີ່ມີຄຸນລັກສະນະ 'ບໍ່ຕ້ອງຕິດຕັ້ງ' (Do not populate)"

#: kicad/cli/command_pcb_export_3d.cpp:103
msgid "Use Grid Origin for output origin"
msgstr "ໃຊ້ຈຸດເລີ່ມຕົ້ນຂອງເສັ້ນຕາໜ່າງ (Grid Origin) ເປັນຈຸດເລີ່ມຕົ້ນສົ່ງອອກ"

#: kicad/cli/command_pcb_export_3d.cpp:107
msgid "Use Drill Origin for output origin"
msgstr "ໃຊ້ຈຸດເລີ່ມຕົ້ນຂອງການເຈາະ (Drill Origin) ເປັນຈຸດເລີ່ມຕົ້ນສົ່ງອອກ"

#: kicad/cli/command_pcb_export_3d.cpp:111
msgid ""
"Substitute STEP or IGS models with the same name in place of VRML models"
msgstr "ໃຊ້ແບບຈຳລອງ STEP ຫຼື IGS ທີ່ມີຊື່ດຽວກັນແທນທີ່ແບບຈຳລອງ VRML"

#: kicad/cli/command_pcb_export_3d.cpp:116
msgid "Only generate a board with no components"
msgstr "ສ້າງສະເພາະແຜ່ນວົງຈອນໂດຍບໍ່ມີອຸປະກອນ"

#: kicad/cli/command_pcb_export_3d.cpp:120
#: pcbnew/dialogs/dialog_export_step_base.cpp:78
msgid "Cut via holes in board body even if conductor layers are not exported."
msgstr "ເຈາະຮູຜ່ານ (via) ໃນຕົວແຜ່ນວົງຈອນ ເຖິງແມ່ນວ່າຈະບໍ່ໄດ້ສົ່ງອອກຊັ້ນຕົວນຳກໍຕາມ."

#: kicad/cli/command_pcb_export_3d.cpp:125
msgid "Exclude board body"
msgstr "ບໍ່ລວມຕົວແຜ່ນວົງຈອນ"

#: kicad/cli/command_pcb_export_3d.cpp:129
msgid "Exclude 3D models for components"
msgstr "ບໍ່ລວມແບບຈຳລອງ 3D ຂອງອຸປະກອນ"

#: kicad/cli/command_pcb_export_3d.cpp:133
msgid ""
"Only include component 3D models matching this list of reference designators "
"(comma-separated, wildcards supported)"
msgstr ""
"ລວມສະເພາະແບບຈຳລອງ 3D ຂອງອຸປະກອນທີ່ກົງກັບລາຍຊື່ອ້າງອີງນີ້ (ຂັ້ນດ້ວຍຈຸດ, ຮອງຮັບ wildcard)"

#: kicad/cli/command_pcb_export_3d.cpp:139
#: pcbnew/dialogs/dialog_export_step_base.cpp:132
msgid "Export tracks and vias"
msgstr "ສົ່ງອອກເສັ້ນວົງຈອນ ແລະ ຮູຜ່ານ (vias)"

#: kicad/cli/command_pcb_export_3d.cpp:143
#: pcbnew/dialogs/dialog_export_step_base.cpp:137
msgid "Export pads"
msgstr "ສົ່ງອອກແຜ່ນຮອງ (pads)"

#: kicad/cli/command_pcb_export_3d.cpp:147
#: pcbnew/dialogs/dialog_export_step_base.cpp:140
msgid "Export zones"
msgstr "ສົ່ງອອກພື້ນທີ່ (zones)"

#: kicad/cli/command_pcb_export_3d.cpp:151
msgid "Export elements on inner copper layers"
msgstr "ສົ່ງອອກອົງປະກອບໃນຊັ້ນທອງແດງພາຍໃນ"

#: kicad/cli/command_pcb_export_3d.cpp:155
msgid "Export silkscreen graphics as a set of flat faces"
msgstr "ສົ່ງອອກກຣາຟິກຊັ້ນຕົວໜັງສື (silkscreen) ເປັນຊຸດຂອງພື້ນຜິວຮາບພຽງ"

#: kicad/cli/command_pcb_export_3d.cpp:159
msgid "Export soldermask layers as a set of flat faces"
msgstr "ສົ່ງອອກຊັ້ນເຄືອບກັນຈອດ (soldermask) ເປັນຊຸດຂອງພື້ນຜິວຮາບພຽງ"

#: kicad/cli/command_pcb_export_3d.cpp:163
msgid "Fuse overlapping geometry together"
msgstr "ລວມຮູບຊົງທີ່ຊ້ອນທັບກັນເຂົ້າດ້ວຍກັນ"

#: kicad/cli/command_pcb_export_3d.cpp:167
#: pcbnew/dialogs/dialog_export_step_base.cpp:154
msgid "Don't cut via holes in conductor layers."
msgstr "ບໍ່ຕ້ອງເຈາະຮູຜ່ານ (via) ໃນຊັ້ນຕົວນຳ."

#: kicad/cli/command_pcb_export_3d.cpp:171
msgid "Disable extra pad thickness (pads will have normal thickness)"
msgstr "ປິດຄວາມໜາພິເສດຂອງແຜ່ນຮອງ (ແຜ່ນຮອງຈະມີຄວາມໜາປົກກະຕິ)"

#: kicad/cli/command_pcb_export_3d.cpp:176
msgid "Minimum distance between points to treat them as separate ones"
msgstr "ໄລຍະຫ່າງຕ່ຳສຸດລະຫວ່າງຈຸດ ເພື່ອຖືວ່າເປັນຈຸດແຍກກັນ"

#: kicad/cli/command_pcb_export_3d.cpp:182
msgid "Only include copper items belonging to nets matching this wildcard"
msgstr "ລວມສະເພາະລາຍການທອງແດງທີ່ເປັນຂອງ Net ທີ່ກົງກັບ wildcard ນີ້"

#: kicad/cli/command_pcb_export_3d.cpp:189
msgid "Do not optimize STEP file (enables writing parametric curves)"
msgstr "ບໍ່ຕ້ອງປັບແຕ່ງ (optimize) ໄຟລ໌ STEP (ເພື່ອໃຫ້ສາມາດຂຽນເສັ້ນໂຄ້ງພາລາມິເຕຣິກໄດ້)"

#: kicad/cli/command_pcb_export_3d.cpp:196
msgid ""
"User-specified output origin ex. 1x1in, 1x1inch, 25.4x25.4mm (default unit "
"mm)"
msgstr "ຈຸດເລີ່ມຕົ້ນສົ່ງອອກທີ່ຜູ້ໃຊ້ກຳນົດ ເຊັ່ນ 1x1in, 1x1inch, 25.4x25.4mm (ຫົວໜ່ວຍເລີ່ມຕົ້ນ ມມ)"

#: kicad/cli/command_pcb_export_3d.cpp:203
msgid "Output units; valid options: mm, m, in, tenths"
msgstr "ຫົວໜ່ວຍສົ່ງອອກ; ຕົວເລືອກ: mm, m, in, tenths"

#: kicad/cli/command_pcb_export_3d.cpp:207
msgid ""
"Name of folder to create and store 3d models in, if not specified or empty, "
"the models will be embedded in main exported VRML file"
msgstr ""
"ຊື່ໂຟນເດີເພື່ອສ້າງ ແລະ ເກັບແບບຈຳລອງ 3D, ຖ້າບໍ່ລະບຸ ຫຼື ປະຫວ່າງ, ແບບຈຳລອງຈະຖືກຝັງໃນໄຟລ໌ VRML ຫຼັກ"

#: kicad/cli/command_pcb_export_3d.cpp:212
msgid "Used with --models-dir to output relative paths in the resulting file"
msgstr "ໃຊ້ຮ່ວມກັບ --models-dir ເພື່ອສົ່ງອອກເສັ້ນທາງແບບສຳພັນ (relative paths) ໃນໄຟລ໌"

#: kicad/cli/command_pcb_export_3d.cpp:290
msgid "Invalid format specified\n"
msgstr "ຮູບແບບທີ່ລະບຸບໍ່ຖືກຕ້ອງ\n"

#: kicad/cli/command_pcb_export_base.cpp:38
msgid ""
"Comma separated list of untranslated layer names to include such as F.Cu,B.Cu"
msgstr "ລາຍຊື່ຊັ້ນທີ່ບໍ່ໄດ້ແປທີ່ຕ້ອງການລວມ (ຂັ້ນດ້ວຍຈຸດ) ເຊັ່ນ F.Cu, B.Cu"

#: kicad/cli/command_pcb_export_base.cpp:48
msgid ""
"Layers to include on each plot, comma separated list of untranslated layer "
"names to include such as F.Cu,B.Cu"
msgstr "ຊັ້ນທີ່ຕ້ອງການລວມໃນແຕ່ລະພລັອດ, ລາຍຊື່ຊັ້ນທີ່ບໍ່ໄດ້ແປ (ຂັ້ນດ້ວຍຈຸດ) ເຊັ່ນ F.Cu, B.Cu"

#: kicad/cli/command_pcb_export_drill.cpp:51
#: pcbnew/dialogs/dialog_gendrill_base.h:90
msgid "Generate Drill Files"
msgstr "ສ້າງໄຟລ໌ເຈາະ"

