msgstr "ນອກແຜ່ນວົງຈອນ, ດ້ານຫຼັງ"

#: pcbnew/dialogs/panel_setup_layers.cpp:541
msgid ""
"Auxiliary layers do not flip with board side, while back and front layers do."
msgstr "ຊັ້ນ Auxiliary ຈະບໍ່ພິກຕາມດ້ານຂອງແຜ່ນວົງຈອນ, ໃນຂະນະທີ່ຊັ້ນ back ແລະ front ຈະພິກຕາມ."

#: pcbnew/dialogs/panel_setup_layers.cpp:876
#, c-format
msgid ""
"Footprints have some items on removed layers:\n"
"%s\n"
"These items will be no longer accessible\n"
"Do you wish to continue?"
msgstr ""
"Footprints ມີບາງລາຍການຢູ່ໃນຊັ້ນທີ່ຖືກລຶບອອກ:\n"
"%s\n"
"ລາຍການເຫຼົ່ານີ້ຈະບໍ່ສາມາດເຂົ້າເຖິງໄດ້ອີກຕໍ່ໄປ\n"
"ທ່ານຕ້ອງການສືບຕໍ່ບໍ່?"

#: pcbnew/dialogs/panel_setup_layers.cpp:915 pcbnew/pad.cpp:2572
#, c-format
msgid "Pad %s of %s on %s"
msgstr "Pad %s ຂອງ %s ໃນ %s"

#: pcbnew/dialogs/panel_setup_layers.cpp:927
msgid ""
"Items have been found on removed layers. This operation will delete all "
"items from removed layers and cannot be undone."
msgstr ""
"ພົບລາຍການຢູ່ໃນຊັ້ນທີ່ຖືກລຶບອອກ. ການກະທຳນີ້ຈະລຶບທຸກລາຍການອອກຈາກຊັ້ນທີ່ຖືກລຶບ ແລະ ບໍ່ສາມາດກັບຄືນຄ່າໄດ້."

#: pcbnew/dialogs/panel_setup_layers.cpp:929
msgid "Show Details"
msgstr "ສະແດງລາຍລະອຽດ"

#: pcbnew/dialogs/panel_setup_layers.cpp:999
msgid "Layer must have a name."
msgstr "ຊັ້ນຕ້ອງມີຊື່."

#: pcbnew/dialogs/panel_setup_layers.cpp:1005
#, c-format
msgid "%s are forbidden in layer names."
msgstr "ຫ້າມໃຊ້ %s ໃນຊື່ຊັ້ນ."

#: pcbnew/dialogs/panel_setup_layers.cpp:1012
msgid "Layer name \"signal\" is reserved."
msgstr "ຊື່ຊັ້ນ \"signal\" ຖືກສະຫງວນໄວ້."

#: pcbnew/dialogs/panel_setup_layers.cpp:1020
#, c-format
msgid "Layer name '%s' already in use."
msgstr "ຊື່ຊັ້ນ '%s' ຖືກໃຊ້ງານແລ້ວ."

#: pcbnew/dialogs/panel_setup_layers.cpp:1133
#, c-format
msgid ""
"Imported settings have fewer copper layers than the current board (%i "
"instead of %i).\n"
"\n"
"Continue and delete the extra inner copper layers from the current board?"
msgstr ""
"ການຕັ້ງຄ່າທີ່ນຳເຂົ້າມີຊັ້ນທອງແດງໜ້ອຍກວ່າແຜ່ນວົງຈອນປະຈຸບັນ (%i ແທນທີ່ຈະເປັນ %i).\n"
"\n"
"ສືບຕໍ່ ແລະ ລຶບຊັ້ນທອງແດງພາຍໃນສ່ວນເກີນອອກຈາກແຜ່ນວົງຈອນປະຈຸບັນບໍ່?"

#: pcbnew/dialogs/panel_setup_layers.cpp:1142
msgid "Inner Layers to Be Deleted"
msgstr "ຊັ້ນພາຍໃນທີ່ຈະຖືກລຶບ"

#: pcbnew/dialogs/panel_setup_layers.cpp:1177
msgid "All user-defined layers have already been added."
msgstr "ເພີ່ມທຸກຊັ້ນທີ່ຜູ້ໃຊ້ກຳນົດເອງແລ້ວ."

#: pcbnew/dialogs/panel_setup_layers.cpp:1181
msgid "Add User-defined Layer"
msgstr "ເພີ່ມຊັ້ນທີ່ຜູ້ໃຊ້ກຳນົດເອງ"

#: pcbnew/dialogs/panel_setup_layers_base.cpp:26
msgid "Add User Defined Layer..."
msgstr "ເພີ່ມຊັ້ນທີ່ຜູ້ໃຊ້ກຳນົດເອງ..."

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:29
msgid ""
"Consult your PCB manufacturer's specifications for solder mask expansion, "
"web width, and clearance settings."
msgstr ""
"ກວດສອບຂໍ້ກຳນົດຂອງຜູ້ຜະລິດ PCB ສຳລັບການຕັ້ງຄ່າ solder mask expansion, web width, ແລະ "
"clearance."

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:33
msgid ""
"If no specifications are provided, setting these values to zero is "
"recommended."
msgstr "ຫາກບໍ່ມີຂໍ້ກຳນົດໃຫ້ມາ, ແນະນຳໃຫ້ຕັ້ງຄ່າເຫຼົ່ານີ້ເປັນສູນ."

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:46
msgid "Solder Mask Settings"
msgstr "ການຕັ້ງຄ່າໜ້າກາກບັດກີ (Solder Mask)"

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:62
#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:67
msgid ""
"Global clearance between pads and the solder mask.\n"
"This value can be superseded by local values for a footprint or a pad.\n"
"Positive clearance means a solder mask opening bigger than the pad (typical "
"for solder mask clearance)."
msgstr ""
"ໄລຍະຫ່າງໂດຍລວມ (Global clearance) ລະຫວ່າງ pad ແລະ solder mask.\n"
"ຄ່ານີ້ສາມາດຖືກຂ້າມໄດ້ໂດຍຄ່າສະເພາະຂອງ footprint ຫຼື pad.\n"
"ຄ່າບວກໝາຍເຖິງຊ່ອງເປີດ solder mask ທີ່ໃຫຍ່ກວ່າ pad (ປົກກະຕິສຳລັບ solder mask clearance)."

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:75
msgid "Solder mask minimum web width:"
msgstr "ຄວາມກວ້າງແຖບ (web) ຕໍ່າສຸດຂອງ solder mask:"

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:77
#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:82
msgid ""
"Minimum distance between openings in the solder mask.\n"
"Pad openings closer than this distance will be plotted as a single opening."
msgstr ""
"ໄລຍະຫ່າງຕໍ່າສຸດລະຫວ່າງຊ່ອງເປີດໃນ solder mask.\n"
"ຊ່ອງເປີດ pad ທີ່ໃກ້ກວ່າໄລຍະນີ້ຈະຖືກແຕ້ມເປັນຊ່ອງເປີດດຽວກັນ."

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:90
msgid "Solder mask to copper clearance:"
msgstr "ໄລຍະຫ່າງລະຫວ່າງ solder mask ຫາທອງແດງ:"

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:92
#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:97
msgid ""
"Minimum distance between a solder mask opening and a copper item with a "
"different net than the solder mask opening's parent.\n"
"Distances smaller than this minimum will create a DRC error."
msgstr ""
"ໄລຍະຫ່າງຕໍ່າສຸດລະຫວ່າງຊ່ອງເປີດ solder mask ແລະ ວັດຖຸທອງແດງທີ່ມີ net ຕ່າງຈາກ net ຂອງຊ່ອງເປີດ "
"solder mask ນັ້ນ.\n"
"ໄລຍະຫ່າງທີ່ນ້ອຍກວ່າຄ່າຕໍ່າສຸດນີ້ຈະເຮັດໃຫ້ເກີດຂໍ້ຜິດພາດ DRC."

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:105
msgid "Allow bridged solder mask apertures between pads within footprints"
msgstr "ອະນຸຍາດໃຫ້ມີຂົວ (bridge) solder mask ລະຫວ່າງ pad ພາຍໃນ footprint"

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:106
msgid ""
"Disable DRC error checking for solder mask aperture bridging between pads in "
"the same footprint."
msgstr ""
"ປິດການກວດສອບ DRC ສຳລັບ solder mask aperture bridging ລະຫວ່າງ pad ໃນ footprint "
"ດຽວກັນ."

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:113
msgid "Tent vias:"
msgstr "ຫຸ້ມ via (Tent vias):"

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:118
#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:123
msgid ""
"Tented: vias are covered with solder mask.\n"
"Not tented: vias are not covered with solder mask."
msgstr ""
"Tented: ຮູ via ຈະຖືກປົກຫຸ້ມດ້ວຍ solder mask.\n"
"Not tented: ຮູ via ຈະບໍ່ຖືກປົກຫຸ້ມດ້ວຍ solder mask."

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:136
msgid "Solder Paste Settings"
msgstr "ການຕັ້ງຄ່າຄີມບັດກີ (Solder Paste)"

#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:167
#: pcbnew/dialogs/panel_setup_mask_and_paste_base.cpp:172
msgid ""
"Global clearance ratio between pads and the solder paste as a percentage of "
"the pad size.\n"
"A value of 10 means the clearance value is 10 percent of the pad size.\n"
"This value can be superseded by local values for a footprint or a pad.\n"
"Final clearance value is the sum of this value and the absolute clearance "
"value."
msgstr ""
"ອັດຕາສ່ວນໄລຍະຫ່າງໂດຍລວມລະຫວ່າງ pad ແລະ solder paste ເປັນເປີເຊັນຂອງຂະໜາດ pad.\n"
"ຄ່າ 10 ໝາຍເຖິງໄລຍະຫ່າງແມ່ນ 10 ເປີເຊັນຂອງຂະໜາດ pad.\n"
"ຄ່ານີ້ສາມາດຖືກຂ້າມໄດ້ໂດຍຄ່າສະເພາະຂອງ footprint ຫຼື pad.\n"
"ໄລຍະຫ່າງສຸດທ້າຍແມ່ນຜົນລວມຂອງຄ່ານີ້ ແລະ ຄ່າໄລຍະຫ່າງສຳບູນ (absolute clearance)."

#: pcbnew/dialogs/panel_setup_rules.cpp:114
msgid "Cancel Changes?"
msgstr "ຍົກເລີກການປ່ຽນແປງບໍ່?"

#: pcbnew/dialogs/panel_setup_rules.cpp:153
msgid "Show Matching Items"
msgstr "ສະແດງລາຍການທີ່ກົງກັນ"

#: pcbnew/dialogs/panel_setup_rules.cpp:206
msgid "Cannot show matching items without an open project."
msgstr "ບໍ່ສາມາດສະແດງລາຍການທີ່ກົງກັນໄດ້ໂດຍບໍ່ມີໂຄງການທີ່ເປີດຢູ່."

#: pcbnew/dialogs/panel_setup_rules.cpp:228
#: pcbnew/dialogs/panel_setup_rules.cpp:246
#: pcbnew/dialogs/panel_setup_rules.cpp:952
msgid "DRC rules"
msgstr "ກົດເກນ DRC"

#: pcbnew/dialogs/panel_setup_rules.cpp:233
#: pcbnew/dialogs/panel_setup_rules.cpp:960
#: pcbnew/drc/drc_rule_condition.cpp:81
#: pcbnew/drc/rule_editor/panel_drc_rule_editor.cpp:952
msgid "ERROR:"
msgstr "ຂໍ້ຜິດພາດ:"

#: pcbnew/dialogs/panel_setup_rules.cpp:326
#, c-format
msgid "Could not scan rules text: %s"
msgstr "ບໍ່ສາມາດສະແກນຂໍ້ຄວາມກົດເກນ: %s"

#: pcbnew/dialogs/panel_setup_rules.cpp:334
msgid "Place the cursor inside a (rule ...) block to show matching items."
msgstr "ວາງເຄີເຊີພາຍໃນບລັອກ (rule ...) ເພື່ອສະແດງລາຍການທີ່ກົງກັນ."

#: pcbnew/dialogs/panel_setup_rules.cpp:343
msgid "The rule under the cursor has no name; add a name to identify it."
msgstr "ກົດເກນທີ່ຢູ່ກ້ອງເຄີເຊີບໍ່ມີຊື່; ກະລຸນາເພີ່ມຊື່ເພື່ອລະບຸຕົວຕົນ."

#: pcbnew/dialogs/panel_setup_rules.cpp:363
#, c-format
msgid "Rule '%s' could not be located after parsing."
msgstr "ບໍ່ພົບກົດເກນ '%s' ຫຼັງຈາກການວິເຄາະ (parsing)."

#: pcbnew/dialogs/panel_setup_rules.cpp:382
msgid "DRC engine not available."
msgstr "ຕົວປະມວນຜົນ DRC ບໍ່ພ້ອມໃຊ້ງານ."

#: pcbnew/dialogs/panel_setup_rules.cpp:405
#, c-format
msgid "Rule '%s': %zu matching item(s)."
msgstr "ກົດເກນ '%s': ພົບ %zu ລາຍການທີ່ກົງກັນ."

#: pcbnew/dialogs/panel_setup_rules.cpp:995
#, c-format
msgid "Rules '%s' and '%s' share the same condition."
msgstr "ກົດເກນ '%s' ແລະ '%s' ໃຊ້ເງື່ອນໄຂດຽວກັນ."

#: pcbnew/dialogs/panel_setup_rules.cpp:1015
