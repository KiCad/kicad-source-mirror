#: eeschema/sch_io/altium/sch_io_altium.cpp:5009
#, c-format
msgid ""
"Could not write a temporary file while extracting the embedded image '%s'."
msgstr "ບໍ່ສາມາດຂຽນໄຟລ໌ຊົ່ວຄາວຂະນະທີ່ກຳລັງສະກັດຮູບພາບທີ່ຝັງໄວ້ '%s'."

#: eeschema/sch_io/altium/sch_io_altium.cpp:5031
#, c-format
msgid ""
"Failed to read embedded image '%s'. The image data may be corrupt or in an "
"unsupported format."
msgstr "ອ່ານຮູບພາບທີ່ຝັງໄວ້ '%s' ບໍ່ສຳເລັດ. ຂໍ້ມູນຮູບພາບອາດຈະເສຍຫາຍ ຫຼື ຢູ່ໃນຮູບແບບທີ່ບໍ່ຮອງຮັບ."

#: eeschema/sch_io/altium/sch_io_altium.cpp:5048
#, c-format
msgid ""
"Could not find image file '%s'. The file path may be specific to a different "
"operating system."
msgstr "ບໍ່ພົບໄຟລ໌ຮູບພາບ '%s'. ເສັ້ນທາງໄຟລ໌ອາດຈະສະເພາະເຈາະຈົງກັບລະບົບປະຕິບັດການອື່ນ."

#: eeschema/sch_io/altium/sch_io_altium.cpp:5066
#, c-format
msgid ""
"Failed to read image file '%s'. The image may be corrupt or in an "
"unsupported format."
msgstr "ອ່ານໄຟລ໌ຮູບພາບ '%s' ບໍ່ສຳເລັດ. ຮູບພາບອາດຈະເສຍຫາຍ ຫຼື ຢູ່ໃນຮູບແບບທີ່ບໍ່ຮອງຮັບ."

#: eeschema/sch_io/altium/sch_io_altium.cpp:5862
#, c-format
msgid "Error parsing Altium library: %s"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການວິເຄາະຄັງ Altium: %s"

#: eeschema/sch_io/altium/sch_io_altium.cpp:5885
