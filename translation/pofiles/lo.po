#: kicad/cli/command_sch_export_plot.cpp:111
#, c-format
msgid "Resolution in dots per inch (default %d)"
msgstr "ຄວາມລະອຽດເປັນ (ເລີ່ມຕົ້ນ %d)"

#: kicad/cli/command_pcb_export_png.cpp:143
#: kicad/cli/command_sch_export_plot.cpp:222
#, c-format
msgid "DPI must be between %d and %d\n"
msgstr "DPI ຕ້ອງຢູ່ລະຫວ່າງ %d ແລະ %d\n"

#: kicad/cli/command_pcb_export_pos.cpp:46
#: pcbnew/dialogs/dialog_gen_footprint_position.cpp:75
msgid "Generate Position File"
msgstr "ສ້າງໄຟລ໌ຕຳແໜ່ງ"

#: kicad/cli/command_pcb_export_pos.cpp:50
msgid ""
"Valid options: front, back, both. Gerber format only supports \"front\" or "
"\"back\"."
msgstr ""
"ຕົວເລືອກ: front (ໜ້າ), back (ຫຼັງ), both (ທັງສອງ). ຮູບແບບ Gerber ຮອງຮັບສະເພາະ "
"\"front\" ຫຼື \"back\"."

#: kicad/cli/command_pcb_export_pos.cpp:55
msgid "Valid options: ascii, csv, gerber"
msgstr "ຕົວເລືອກ: ascii, csv, gerber"

#: kicad/cli/command_pcb_export_pos.cpp:60
msgid "Output units; ascii or csv format only; valid options: in, mm"
msgstr "ຫົວໜ່ວຍສົ່ງອອກ; ສະເພາະຮູບແບບ ascii ຫຼື csv; ຕົວເລືອກ: in, mm"

#: kicad/cli/command_pcb_export_pos.cpp:64
msgid ""
"Use negative X coordinates for footprints on bottom layer (ascii or csv "
"formats only)"
msgstr "ໃຊ້ພິກັດ X ຄ່າລົບສຳລັບຟຸດປຣິນໃນຊັ້ນລຸ່ມ (ສະເພາະຮູບແບບ ascii ຫຼື csv)"

#: kicad/cli/command_pcb_export_pos.cpp:69
msgid "Use drill/place file origin (ascii or csv only)"
msgstr "ໃຊ້ຈຸດເລີ່ມຕົ້ນຂອງໄຟລ໌ເຈາະ/ຕຳແໜ່ງ (ສະເພາະ ascii ຫຼື csv)"

#: kicad/cli/command_pcb_export_pos.cpp:73
msgid "Include only SMD footprints (ascii or csv only)"
msgstr "ລວມສະເພາະຟຸດປຣິນ SMD (ສະເພາະ ascii ຫຼື csv)"

#: kicad/cli/command_pcb_export_pos.cpp:78
msgid "Exclude all footprints with through-hole pads (ascii or csv only)"
msgstr "ບໍ່ລວມທຸກຟຸດປຣິນທີ່ມີແຜ່ນຮອງແບບຮູເຈາະ (through-hole) (ສະເພາະ ascii ຫຼື csv)"

#: kicad/cli/command_pcb_export_pos.cpp:82
#: pcbnew/dialogs/dialog_gen_footprint_position_file_base.cpp:110
msgid "Exclude all footprints with the Do Not Populate flag set"
msgstr "ບໍ່ລວມທຸກຟຸດປຣິນທີ່ຕັ້ງຄ່າ 'ບໍ່ຕ້ອງຕິດຕັ້ງ' (Do Not Populate)"

#: kicad/cli/command_pcb_export_pos.cpp:86
msgid "Include board edge layer (Gerber only)"
msgstr "ລວມຊັ້ນຂອບແຜ່ນວົງຈອນ (ສະເພາະ Gerber)"

#: kicad/cli/command_pcb_export_pos.cpp:134
#: kicad/cli/command_sch_export_netlist.cpp:97 kicad/cli/command_version.cpp:71
msgid "Invalid format\n"
msgstr "ຮູບແບບບໍ່ຖືກຕ້ອງ\n"

#: kicad/cli/command_pcb_export_pos.cpp:160
msgid "\"both\" not supported for Gerber format\n"
msgstr "ບໍ່ຮອງຮັບ \"both\" ສຳລັບຮູບແບບ Gerber\n"

#: kicad/cli/command_pcb_export_pos.cpp:176
msgid "Invalid side specified\n"
msgstr "ລະບຸດ້າານບໍ່ຖືກຕ້ອງ\n"

#: kicad/cli/command_pcb_export_ps.cpp:39
msgid "Generate Postscript from a list of layers"
msgstr "ສ້າງ Postscript ຈາກລາຍຊື່ຊັ້ນ"

#: kicad/cli/command_pcb_export_ps.cpp:118
msgid ""
"Track width correction [mm]. Used to compensate errors in track widths, pad "
"and via sizes."
msgstr ""
"ການແກ້ໄຂຄວາມກວ້າງເສັ້ນວົງຈອນ [ມມ]. ໃຊ້ເພື່ອຊົດເຊີຍຂໍ້ຜິດພາດຂອງຄວາມກວ້າງເສັ້ນ, ແຜ່ນຮອງ ແລະ "
"ຂະໜາດຮູຜ່ານ."

#: kicad/cli/command_pcb_export_ps.cpp:125
msgid "X scale adjust for exact scale."
msgstr "ປັບມາດຕາສ່ວນ X ເພື່ອໃຫ້ໄດ້ມາດຕາສ່ວນທີ່ແນ່ນອນ."

#: kicad/cli/command_pcb_export_ps.cpp:131
msgid "Y scale adjust for exact scale."
msgstr "ປັບມາດຕາສ່ວນ Y ເພື່ອໃຫ້ໄດ້ມາດຕາສ່ວນທີ່ແນ່ນອນ."

#: kicad/cli/command_pcb_export_ps.cpp:137
msgid "Force A4 paper size."
msgstr "ບັງຄັບໃຫ້ໃຊ້ຂະໜາດເຈ້ຍ A4."

#: kicad/cli/command_pcb_export_stats.cpp:36
msgid "Generate a board statistics report"
msgstr "ສ້າງລາຍງານສະຖິຕິແຜ່ນວົງຈອນ"

#: kicad/cli/command_pcb_export_stats.cpp:45
msgid "Report units; valid options: in, mm"
msgstr "ຫົວໜ່ວຍລາຍງານ; ຕົວເລືອກ: in, mm"

#: kicad/cli/command_pcb_export_stats.cpp:49
msgid "Exclude footprints without pads"
msgstr "ບໍ່ລວມຟຸດປຣິນທີ່ບໍ່ມີແຜ່ນຮອງ"

#: kicad/cli/command_pcb_export_stats.cpp:53
msgid "Subtract holes from the board area"
msgstr "ລົບພື້ນທີ່ຮູເຈາະອອກຈາກພື້ນທີ່ແຜ່ນວົງຈອນ"

#: kicad/cli/command_pcb_export_stats.cpp:57
#: pcbnew/dialogs/dialog_board_statistics_base.cpp:208
#: pcbnew/dialogs/dialog_board_stats_job_base.cpp:62
msgid "Subtract holes from copper areas"
msgstr "ລົບພື້ນທີ່ຮູເຈາະອອກຈາກພື້ນທີ່ທອງແດງ"

#: kicad/cli/command_pcb_export_svg.cpp:41
msgid "Generate SVG outputs of a given layer list"
msgstr "ສ້າງຜົນສົ່ງອອກ SVG ຈາກລາຍຊື່ຊັ້ນທີ່ລະບຸ"

#: kicad/cli/command_pcb_export_svg.cpp:90
msgid ""
"Set page sizing mode (0 = page with frame and title block, 1 = current page "
"size, 2 = board area only)"
msgstr ""
"ຕັ້ງຄ່າໂໝດຂະໜາດໜ້າ (0 = ໜ້າທີ່ມີຂອບ ແລະ ຫົວຂໍ້, 1 = ຂະໜາດໜ້າປັດຈຸບັນ, 2 = ສະເພາະພື້ນທີ່ແຜ່ນວົງຈອນ)"

#: kicad/cli/command_pcb_export_svg.cpp:97
msgid "Fit the page to the board"
msgstr "ປັບຂະໜາດໜ້າໃຫ້ພໍດີກັບແຜ່ນວົງຈອນ"

#: kicad/cli/command_pcb_export_svg.cpp:101
#: kicad/cli/command_sch_export_plot.cpp:72
msgid "No drawing sheet"
msgstr "ບໍ່ມີແຜ່ນແຕ້ມ"

#: kicad/cli/command_pcb_import.cpp:42
msgid "Import a non-KiCad PCB file to KiCad format"
msgstr "ນຳເຂົ້າໄຟລ໌ PCB ທີ່ບໍ່ແມ່ນ KiCad ເປັນຮູບແບບ KiCad"

#: kicad/cli/command_pcb_import.cpp:46
msgid ""
"Input format hint: auto, pads, altium, eagle, cadstar, fabmaster, pcad, "
"solidworks (default: auto)"
msgstr ""
"ຄຳແນະນຳຮູບແບບນຳເຂົ້າ: auto, pads, altium, eagle, cadstar, fabmaster, pcad, "
"solidworks (ເລີ່ມຕົ້ນ: auto)"

#: kicad/cli/command_pcb_import.cpp:52 kicad/cli/command_sch_import.cpp:50
msgid "Import report format: none, json, text (default: none)"
msgstr "ຮູບແບບລາຍງານການນຳເຂົ້າ: none, json, text (ເລີ່ມຕົ້ນ: none)"

#: kicad/cli/command_pcb_import.cpp:57 kicad/cli/command_sch_import.cpp:55
msgid "File path for import report (default: stdout)"
msgstr "ເສັ້ນທາງໄຟລ໌ສຳລັບລາຍງານການນຳເຂົ້າ (ເລີ່ມຕົ້ນ: stdout)"

#: kicad/cli/command_pcb_import.cpp:62
msgid ""
"JSON file mapping source layer names to KiCad layer names; unmapped layers "
"use the automatic best-guess"
msgstr ""
"ໄຟລ໌ JSON ທີ່ຈັບຄູ່ຊື່ຊັ້ນແຫຼ່ງທີ່ມາກັບຊື່ຊັ້ນ KiCad; ຊັ້ນທີ່ບໍ່ໄດ້ຈັບຄູ່ຈະຖືກຄາດເດົາໃຫ້ດີທີ່ສຸດໂດຍອັດຕະໂນມັດ"

#: kicad/cli/command_pcb_import.cpp:111 kicad/cli/command_sch_import.cpp:91
#, c-format
msgid "Invalid format: %s\n"
msgstr "ຮູບແບບບໍ່ຖືກຕ້ອງ: %s\n"

#: kicad/cli/command_pcb_import.cpp:119 kicad/cli/command_sch_import.cpp:99
#, c-format
msgid "Invalid report format: %s\n"
msgstr "ຮູບແບບລາຍງານບໍ່ຖືກຕ້ອງ: %s\n"

#: kicad/cli/command_pcb_render.cpp:221
msgid "Renders the PCB in 3D view to PNG or JPEG image"
msgstr "ສະແດງຜົນ PCB ໃນຮູບແບບ 3D ເປັນຮູບພາບ PNG ຫຼື JPEG"

#: kicad/cli/command_pcb_render.cpp:227
msgid "Image width"
msgstr "ຄວາມກວ້າງຂອງຮູບພາບ"

#: kicad/cli/command_pcb_render.cpp:233
msgid "Image height"
msgstr "ຄວາມສູງຂອງຮູບພາບ"

#: kicad/cli/command_pcb_render.cpp:239
#, c-format
msgid "Render from side. Options: %s"
msgstr "ສະແດງຜົນຈາກດ້ານຂ້າງ. ຕົວເລືອກ: %s"

#: kicad/cli/command_pcb_render.cpp:244
#, c-format
msgid ""
"Image background. Options: %s. Default: transparent for PNG, opaque for JPEG"
msgstr "ພື້ນຫຼັງຮູບພາບ. ຕົວເລືອກ: %s. ຄ່າເລີ່ມຕົ້ນ: ໂປ່ງໃສສຳລັບ PNG, ທຶບແສງສຳລັບ JPEG"

#: kicad/cli/command_pcb_render.cpp:253
#, c-format
msgid "Render quality. Options: %s"
msgstr "ຄຸນນະພາບການສະແດງຜົນ. ຕົວເລືອກ: %s"

#: kicad/cli/command_pcb_render.cpp:259
#, c-format
msgid "Appearance preset. Options: %s, %s, or user-defined preset name"
msgstr "ຮູບແບບລັກສະນະທີ່ຕັ້ງໄວ້ລ່ວງໜ້າ. ຕົວເລືອກ: %s, %s, ຫຼື ຊື່ທີ່ຜູ້ໃຊ້ກຳນົດເອງ"

#: kicad/cli/command_pcb_render.cpp:266
msgid "Use colors defined in the board stackup instead of those in the preset"
msgstr "ໃຊ້ສີທີ່ກຳນົດໃນການຈັດຊັ້ນແຜ່ນວົງຈອນ ແທນທີ່ສີໃນຄ່າທີ່ຕັ້ງໄວ້ລ່ວງໜ້າ"

#: kicad/cli/command_pcb_render.cpp:271
msgid ""
"Enables floor, shadows and post-processing, even if disabled in quality "
"setting"
msgstr ""
"ເປີດໃຊ້ງານພື້ນ, ເງົາ ແລະ ການປະມວນຜົນຂັ້ນສຸດທ້າຍ, ເຖິງແມ່ນວ່າຈະປິດໄວ້ໃນການຕັ້ງຄ່າຄຸນນະພາບກໍຕາມ"

#: kicad/cli/command_pcb_render.cpp:276
msgid "Use perspective projection instead of orthogonal"
msgstr "ໃຊ້ການສາຍພາບແບບເບິ່ງໄກ (Perspective) ແທນແບບຕັ້ງສາກ (Orthogonal)"

#: kicad/cli/command_pcb_render.cpp:282
msgid "Camera zoom"
msgstr "ການຊູມຂອງກ້ອງ"

#: kicad/cli/command_pcb_render.cpp:287
msgid "Pan camera, format 'X,Y,Z' e.g.: '3,0,0'"
msgstr "ເລື່ອນກ້ອງ, ຮູບແບບ 'X,Y,Z' ຕົວຢ່າງ: '3,0,0'"

#: kicad/cli/command_pcb_render.cpp:292
msgid ""
"Set pivot point relative to the board center in centimeters, format 'X,Y,Z' "
"e.g.: '-10,2,0'"
msgstr "ຕັ້ງຈຸດໝູນທຽບກັບຈຸດໃຈກາງແຜ່ນວົງຈອນເປັນຊັງຕີແມັດ, ຮູບແບບ 'X,Y,Z' ຕົວຢ່າງ: '-10,2,0'"

#: kicad/cli/command_pcb_render.cpp:299
msgid "Rotate board, format 'X,Y,Z' e.g.: '-45,0,45' for isometric view"
msgstr "ໝູນແຜ່ນວົງຈອນ, ຮູບແບບ 'X,Y,Z' ຕົວຢ່າງ: '-45,0,45' ສຳລັບມຸມເບິ່ງໄອໂຊເມຕຣິກ"

#: kicad/cli/command_pcb_render.cpp:304
msgid "Top light intensity, format 'R,G,B' or a single number, range: 0-1"
msgstr "ຄວາມເຂັ້ມແສງດ້ານເທິງ, ຮູບແບບ 'R,G,B' ຫຼື ຕົວເລກດ່ຽວ, ຊ່ວງ: 0-1"

#: kicad/cli/command_pcb_render.cpp:309
msgid "Bottom light intensity, format 'R,G,B' or a single number, range: 0-1"
msgstr "ຄວາມເຂັ້ມແສງດ້ານລຸ່ມ, ຮູບແບບ 'R,G,B' ຫຼື ຕົວເລກດ່ຽວ, ຊ່ວງ: 0-1"

#: kicad/cli/command_pcb_render.cpp:314
msgid "Side lights intensity, format 'R,G,B' or a single number, range: 0-1"
msgstr "ຄວາມເຂັ້ມແສງດ້ານຂ້າງ, ຮູບແບບ 'R,G,B' ຫຼື ຕົວເລກດ່ຽວ, ຊ່ວງ: 0-1"

#: kicad/cli/command_pcb_render.cpp:319
msgid "Camera light intensity, format 'R,G,B' or a single number, range: 0-1"
msgstr "ຄວາມເຂັ້ມແສງຂອງກ້ອງ, ຮູບແບບ 'R,G,B' ຫຼື ຕົວເລກດ່ຽວ, ຊ່ວງ: 0-1"

#: kicad/cli/command_pcb_render.cpp:325
msgid "Side lights elevation angle in degrees, range: 0-90"
msgstr "ມຸມເງີຍຂອງແສງດ້ານຂ້າງເປັນອົງສາ, ຊ່ວງ: 0-90"

#: kicad/cli/command_pcb_render.cpp:344
msgid "Invalid preset\n"
msgstr "ຄ່າທີ່ຕັ້ງໄວ້ລ່ວງໜ້າບໍ່ຖືກຕ້ອງ\n"

#: kicad/cli/command_pcb_render.cpp:362
msgid "Invalid background\n"
msgstr "ພື້ນຫຼັງບໍ່ຖືກຕ້ອງ\n"

#: kicad/cli/command_pcb_render.cpp:368
msgid "Invalid rotation format\n"
msgstr "ຮູບແບບການໝູນບໍ່ຖືກຕ້ອງ\n"

#: kicad/cli/command_pcb_render.cpp:374
msgid "Invalid pan format\n"
msgstr "ຮູບແບບການເລື່ອນບໍ່ຖືກຕ້ອງ\n"

#: kicad/cli/command_pcb_render.cpp:380
msgid "Invalid pivot format\n"
msgstr "ຮູບແບບຈຸດໝູນບໍ່ຖືກຕ້ອງ\n"

#: kicad/cli/command_pcb_render.cpp:387
msgid "Invalid light top intensity format\n"
