#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:238
#, c-format
msgid "Unsupported DipTrace schematic format version %d."
msgstr "ບໍ່ຮອງຮັບຮູບແບບຜັງວົງຈອນ DipTrace ເວີຊັນ %d."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:284
#, c-format
msgid "DipTrace import: unexpected error at offset 0x%06zX: %s"
msgstr "ນຳເຂົ້າ DipTrace: ເກີດຂໍ້ຜິດພາດທີ່ບໍ່ຄາດຄິດຢູ່ທີ່ອັອຟເຊັດ 0x%06zX: %s"

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:298
#, c-format
msgid "Invalid DipTrace schematic magic length: %d (expected 7 or 11)."
msgstr "ຄວາມຍາວ magic ຂອງຜັງວົງຈອນ DipTrace ບໍ່ຖືກຕ້ອງ: %d (ຄາດໄວ້ແມ່ນ 7 ຫຼື 11)."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:306
msgid "Invalid DipTrace schematic file: bad magic header."
msgstr "ໄຟລ໌ຜັງວົງຈອນ DipTrace ບໍ່ຖືກຕ້ອງ: ສ່ວນຫົວ (magic header) ບໍ່ດີ."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:320
msgid "Invalid DipTrace schematic file: bad legacy version suffix."
msgstr "ໄຟລ໌ຜັງວົງຈອນ DipTrace ບໍ່ຖືກຕ້ອງ: ນາມສະກຸນເວີຊັນເກົ່າ (suffix) ບໍ່ດີ."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:335
#, c-format
msgid "Invalid DipTrace schematic sheet count: %d."
msgstr "ຈຳນວນແຜ່ນງານຜັງວົງຈອນ DipTrace ບໍ່ຖືກຕ້ອງ: %d."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:397
#, c-format
msgid "Invalid text style count: %d."
msgstr "ຈຳນວນຮູບແບບຂໍ້ຄວາມບໍ່ຖືກຕ້ອງ: %d."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:455
#, c-format
msgid "DipTrace import: invalid component count %d."
msgstr "ນຳເຂົ້າ DipTrace: ຈຳນວນສ່ວນປະກອບບໍ່ຖືກຕ້ອງ %d."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:482
#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:2207
#, c-format
msgid "DipTrace import: invalid bus count %d."
msgstr "ນຳເຂົ້າ DipTrace: ຈຳນວນບັສບໍ່ຖືກຕ້ອງ %d."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:698
#, c-format
msgid "DipTrace import: failed to parse component %zu at offset 0x%06zX: %s"
msgstr "ນຳເຂົ້າ DipTrace: ວິເຄາະສ່ວນປະກອບ %zu ຢູ່ທີ່ອັອຟເຊັດ 0x%06zX ບໍ່ສຳເລັດ: %s"

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:706
#, c-format
msgid "DipTrace import: found %zu components, but the file header declares %d."
msgstr "ນຳເຂົ້າ DipTrace: ພົບສ່ວນປະກອບ %zu ຢ່າງ, ແຕ່ສ່ວນຫົວໄຟລ໌ລະບຸໄວ້ %d ຢ່າງ."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:963
#, c-format
msgid ""
"DipTrace import: invalid component extra-tail length %u at offset 0x%06zX."
msgstr ""
"ນຳເຂົ້າ DipTrace: ຄວາມຍາວ extra-tail ຂອງສ່ວນປະກອບບໍ່ຖືກຕ້ອງ %u ຢູ່ທີ່ອັອຟເຊັດ 0x%06zX."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:1111
#, c-format
msgid "Invalid pin count %d at component offset 0x%06zX."
msgstr "ຈຳນວນຂາບໍ່ຖືກຕ້ອງ %d ຢູ່ທີ່ອັອຟເຊັດສ່ວນປະກອບ 0x%06zX."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:1187
#, c-format
msgid ""
"DipTrace import: failed to parse pin %d in component at 0x%06zX (offset "
"0x%06zX): %s"
msgstr ""
"ນຳເຂົ້າ DipTrace: ວິເຄາະຂາ %d ໃນສ່ວນປະກອບຢູ່ທີ່ 0x%06zX (ອັອຟເຊັດ 0x%06zX) ບໍ່ສຳເລັດ: %s"

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:1311
#, c-format
msgid ""
"DipTrace import: invalid component shape point count %d at offset 0x%06zX."
msgstr "ນຳເຂົ້າ DipTrace: ຈຳນວນຈຸດຮູບຊົງສ່ວນປະກອບບໍ່ຖືກຕ້ອງ %d ຢູ່ທີ່ອັອຟເຊັດ 0x%06zX."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:1940
#, c-format
msgid ""
"DipTrace import: invalid embedded pattern %s count %d at offset 0x%06zX."
msgstr "ນຳເຂົ້າ DipTrace: ຈຳນວນແພັດເທີນທີ່ຝັງໄວ້ %s ບໍ່ຖືກຕ້ອງ %d ຢູ່ທີ່ອັອຟເຊັດ 0x%06zX."

#: eeschema/sch_io/diptrace/diptrace_sch_parser.cpp:2231
