msgstr "ຟິວຂອງການຖົມ (fill) ບໍ່ພຽງພໍ"

#: pcbnew/pcb_io/autotrax/autotrax_parser.cpp:243
msgid "insufficient text fields"
msgstr "ຟິວຂອງຂໍ້ຄວາມບໍ່ພຽງພໍ"

#: pcbnew/pcb_io/autotrax/autotrax_parser.cpp:292
msgid "insufficient component fields"
msgstr "ຟິວຂອງອຸປະກອນບໍ່ພຽງພໍ"

#: pcbnew/pcb_io/autotrax/pcb_io_autotrax.cpp:147
#, c-format
msgid "Could not read file '%s'."
msgstr "ບໍ່ສາມາດອ່ານໄຟລ໌ '%s'."

#: pcbnew/pcb_io/autotrax/pcb_io_autotrax.cpp:155
#, c-format
msgid "'%s' is not a valid Protel Autotrax file."
msgstr "'%s' ບໍ່ແມ່ນໄຟລ໌ Protel Autotrax ທີ່ຖືກຕ້ອງ."

#: pcbnew/pcb_io/autotrax/pcb_io_autotrax.h:62
msgid "Protel Autotrax / Easytrax PCB files"
msgstr "ໄຟລ໌ Protel Autotrax / Easytrax PCB"

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:94
msgid ""
"The selected file indicates that nets might be out of synchronisation with "
"the schematic. It is recommended that you carry out an 'Align Nets' "
"procedure in CADSTAR and re-import, to avoid inconsistencies between the PCB "
"and the schematic. "
msgstr ""
"ໄຟລ໌ທີ່ເລືອກລະບຸວ່າເນັດ (nets) ອາດຈະບໍ່ກົງກັບຜັງວົງຈອນ (schematic). ແນະນຳໃຫ້ທ່ານເຮັດຂັ້ນຕອນ "
"'Align Nets' ໃນ CADSTAR ແລະ ນຳເຂົ້າຄືນໃໝ່ ເພື່ອຫຼີກເວັ້ນຄວາມບໍ່ສອດຄ່ອງກັນລະຫວ່າງ PCB ແລະ "
"ຜັງວົງຈອນ. "

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:134
#, c-format
msgid ""
"Unable to determine zone fill priorities for layer '%s'. A best attempt has "
"been made but it is possible that DRC errors exist and that manual editing "
"of the zone priorities is required."
msgstr ""
"ບໍ່ສາມາດກຳນົດລຳດັບຄວາມສຳຄັນຂອງການຖົມໂຊນສຳລັບຊັ້ນ '%s'. ໄດ້ພະຍາຍາມທີ່ສຸດແລ້ວ "
"ແຕ່ອາດຈະຍັງມີຂໍ້ຜິດພາດ DRC ແລະ ອາດຕ້ອງແກ້ໄຂລຳດັບຄວາມສຳຄັນຂອງໂຊນດ້ວຍຕົນເອງ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:148
msgid ""
"The CADSTAR design contains Trunk routing elements, which have no KiCad "
"equivalent. These elements were not loaded."
msgstr ""
"ການອອກແບບ CADSTAR ນີ້ມີອົງປະກອບ Trunk routing ເຊິ່ງບໍ່ມີໃນ KiCad. "
"ອົງປະກອບເຫຼົ່ານີ້ບໍ່ໄດ້ຖືກໂຫຼດມາ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:155
#, c-format
msgid ""
"The CADSTAR design contains variants which has no KiCad equivalent. Only the "
"variant '%s' was loaded."
msgstr ""
"ການອອກແບບ CADSTAR ນີ້ມີຕົວປ່ຽນ (variants) ທີ່ບໍ່ມີໃນ KiCad. ຈະໂຫຼດສະເພາະຕົວປ່ຽນ '%s' "
"ເທົ່ານັ້ນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:167
msgid ""
"CADSTAR fonts are different to the ones in KiCad. This will likely result in "
"alignment issues that may cause DRC errors. Please review the imported text "
"elements carefully and correct manually if required."
msgstr ""
"ຟອນຂອງ CADSTAR ແຕກຕ່າງຈາກ KiCad. ນີ້ອາດຈະເຮັດໃຫ້ເກີດບັນຫາການຈັດວາງ ແລະ ຂໍ້ຜິດພາດ DRC. "
"ກະລຸນາກວດສອບຂໍ້ຄວາມທີ່ນຳເຂົ້າມາຢ່າງລະອຽດ ແລະ ແກ້ໄຂດ້ວຍຕົນເອງຖ້າຈຳເປັນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:243
#, c-format
msgid ""
"The CADSTAR layer '%s' has no KiCad equivalent. All elements on this layer "
"have been mapped to KiCad layer '%s' instead."
msgstr ""
"ຊັ້ນ CADSTAR '%s' ບໍ່ມີຊັ້ນ KiCad ທີ່ທຽບເທົ່າ. ອົງປະກອບທັງໝົດໃນຊັ້ນນີ້ຖືກຈັບຄູ່ກັບຊັ້ນ KiCad '%s' ແທນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:256
#, c-format
msgid ""
"The CADSTAR layer '%s' has been assumed to be a technical layer. All "
"elements on this layer have been mapped to KiCad layer '%s'."
msgstr ""
"ຊັ້ນ CADSTAR '%s' ຖືກສົມມຸດວ່າເປັນຊັ້ນເຕັກນິກ (technical layer). "
"ອົງປະກອບທັງໝົດໃນຊັ້ນນີ້ຖືກຈັບຄູ່ກັບຊັ້ນ KiCad '%s'."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:328
#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:352
#, c-format
msgid ""
"The CADSTAR construction layer '%s' is on the outer surface of the board. It "
"has been ignored."
msgstr "ຊັ້ນກໍ່ສ້າງ CADSTAR '%s' ຢູ່ດ້ານນອກຂອງບອດ. ມັນຖືກຍົກເວັ້ນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:591
#, c-format
msgid "Unexpected layer '%s' in layer stack."
msgstr "ພົບຊັ້ນ '%s' ທີ່ບໍ່ຄາດຄິດໃນຊັ້ນລຽງຊ້ອນ (layer stack)."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:748
#, c-format
msgid "Design rule %s was not found. This was ignored."
msgstr "ບໍ່ພົບກົດການອອກແບບ %s. ມັນຖືກຍົກເວັ້ນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:777
msgid ""
"KiCad design rules are different from CADSTAR ones. Only the compatible "
"design rules were imported. It is recommended that you review the design "
"rules that have been applied."
msgstr ""
"ກົດການອອກແບບຂອງ KiCad ແຕກຕ່າງຈາກ CADSTAR. ຈະນຳເຂົ້າສະເພາະກົດທີ່ເຂົ້າກັນໄດ້ເທົ່ານັ້ນ. "
"ແນະນຳໃຫ້ທ່ານກວດສອບກົດການອອກແບບທີ່ຖືກນຳໃຊ້ອີກຄັ້ງ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:981
#, c-format
msgid ""
"The CADSTAR area '%s' in library component '%s' does not have a KiCad "
"equivalent. The area is neither a via nor route keepout area. The area was "
"not imported."
msgstr ""
"ພື້ນທີ່ CADSTAR '%s' ໃນອຸປະກອນຫ້ອງສະໝຸດ '%s' ບໍ່ມີສິ່ງທີ່ທຽບເທົ່າໃນ KiCad. "
"ພື້ນທີ່ນີ້ບໍ່ແມ່ນທັງເຂດຫ້າມວາງວີອາ (via keepout) ຫຼື ເຂດຫ້າມລາກເສັ້ນ (route keepout). "
"ພື້ນທີ່ນີ້ຈຶ່ງບໍ່ໄດ້ຖືກນຳເຂົ້າ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1075
#, c-format
msgid ""
"The CADSTAR pad definition '%s' is a complex pad stack, which is not "
"supported in KiCad. Please review the imported pads as they may require "
"manual correction."
msgstr ""
"ການກຳນົດແພັດ CADSTAR '%s' ເປັນໂຄງສ້າງແພັດທີ່ຊັບຊ້ອນ (complex pad stack) ເຊິ່ງ KiCad "
"ຍັງບໍ່ຮອງຮັບ. ກະລຸນາກວດສອບແພັດທີ່ນຳເຂົ້າມາ ເພາະອາດຕ້ອງແກ້ໄຂດ້ວຍຕົນເອງ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1295
#, c-format
msgid ""
"The CADSTAR pad definition '%s' has the hole shape outside the pad shape. "
"The hole has been moved to the center of the pad."
msgstr "ການກຳນົດແພັດ CADSTAR '%s' ມີຮູບຊົງຮູຢູ່ນອກຮູບຊົງແພັດ. ຮູໄດ້ຖືກຍ້າຍມາໄວ້ທີ່ໃຈກາງຂອງແພັດ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1325
#, c-format
msgid "The CADSTAR pad definition '%s' has import errors: %s"
msgstr "ການກຳນົດແພັດ CADSTAR '%s' ມີຂໍ້ຜິດພາດໃນການນຳເຂົ້າ: %s"

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1342
#, c-format
msgid "Unable to find pad index '%d' in footprint '%s'."
msgstr "ບໍ່ພົບດັດຊະນີແພັດ '%d' ໃນຮອຍຕີນອຸປະກອນ '%s'."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1375
#, c-format
msgid "Unable to find group ID %s in the group definitions."
msgstr "ບໍ່ພົບ ID ກຸ່ມ %s ໃນການກຳນົດກຸ່ມ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1380
#, c-format
msgid ""
"Unable to find sub group %s in the group map (parent group ID=%s, Name=%s)."
msgstr "ບໍ່ພົບກຸ່ມຍ່ອຍ %s ໃນແຜນຜັງກຸ່ມ (ID ກຸ່ມແມ່=%s, ຊື່=%s)."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1456
#, c-format
msgid ""
"Dimension ID %s is an angled dimension, which has no KiCad equivalent. An "
"aligned dimension was loaded instead."
msgstr ""
"ID ການບອກຂະໜາດ %s ເປັນແບບເຮັດມຸມ (angled dimension) ເຊິ່ງບໍ່ມີໃນ KiCad. "
"ຈະໃຊ້ການບອກຂະໜາດແບບຈັດວາງກົງ (aligned dimension) ແທນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1465
#, c-format
msgid ""
"Dimension ID %s has 'External' style in CADSTAR. External dimension styles "
"are not yet supported in KiCad. The dimension object was imported with an "
"internal dimension style instead."
msgstr ""
"ID ການບອກຂະໜາດ %s ມີຮູບແບບ 'External' ໃນ CADSTAR. "
"ຮູບແບບການບອກຂະໜາດພາຍນອກຍັງບໍ່ຮອງຮັບໃນ KiCad. "
"ວັດຖຸການບອກຂະໜາດຈະຖືກນຳເຂົ້າດ້ວຍຮູບແບບພາຍໃນແທນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1522
#, c-format
msgid "Unexpected Dimension type (ID %s). This was not imported."
msgstr "ພົບປະເພດການບອກຂະໜາດທີ່ບໍ່ຄາດຄິດ (ID %s). ມັນບໍ່ໄດ້ຖືກນຳເຂົ້າ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1656
#, c-format
msgid ""
"Dimension %s is an angular dimension which has no KiCad equivalent. The "
"object was not imported."
msgstr "ການບອກຂະໜາດ %s ເປັນແບບມຸມອົງສາ ເຊິ່ງບໍ່ມີໃນ KiCad. ວັດຖຸນີ້ບໍ່ໄດ້ຖືກນຳເຂົ້າ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1696
#, c-format
msgid ""
"The CADSTAR area '%s' is marked as a placement area in CADSTAR. Placement "
"areas are not supported in KiCad. Only the supported elements for the area "
"were imported."
msgstr ""
"ພື້ນທີ່ CADSTAR '%s' ຖືກໝາຍວ່າເປັນພື້ນທີ່ວາງອຸປະກອນ (placement area) ໃນ CADSTAR. KiCad "
"ຍັງບໍ່ຮອງຮັບພື້ນທີ່ວາງອຸປະກອນ. ຈະນຳເຂົ້າສະເພາະອົງປະກອບທີ່ຮອງຮັບສຳລັບພື້ນທີ່ນີ້ເທົ່ານັ້ນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1704
#, c-format
msgid ""
"The CADSTAR area '%s' does not have a KiCad equivalent. Pure Placement areas "
"are not supported."
msgstr ""
"ພື້ນທີ່ CADSTAR '%s' ບໍ່ມີສິ່ງທີ່ທຽບເທົ່າໃນ KiCad. ບໍ່ຮອງຮັບພື້ນທີ່ວາງອຸປະກອນບໍລິສຸດ (Pure Placement "
"areas)."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1731
#, c-format
msgid "Unable to find component '%s' in the library (Symdef ID: '%s')"
msgstr "ບໍ່ພົບອຸປະກອນ '%s' ໃນຫ້ອງສະໝຸດ (Symdef ID: '%s')"

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1853
#, c-format
msgid "Unable to find documentation symbol in the library (Symdef ID: '%s')"
msgstr "ບໍ່ພົບສັນຍະລັກເອກະສານໃນຫ້ອງສະໝຸດ (Symdef ID: '%s')"

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1920
#, c-format
msgid ""
"The CADSTAR template '%s' has the setting 'Allow in No Routing Areas' "
"enabled. This setting has no KiCad equivalent, so it has been ignored."
msgstr ""
"ເທມເພດ CADSTAR '%s' ມີການຕັ້ງຄ່າ 'Allow in No Routing Areas' ເປີດໄວ້. ການຕັ້ງຄ່ານີ້ບໍ່ມີໃນ "
"KiCad, ມັນຈຶ່ງຖືກຍົກເວັ້ນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1928
#, c-format
msgid ""
"The CADSTAR template '%s' has the setting 'Box Isolated Pins' enabled. This "
"setting has no KiCad equivalent, so it has been ignored."
msgstr ""
"ເທມເພດ CADSTAR '%s' ມີການຕັ້ງຄ່າ 'Box Isolated Pins' ເປີດໄວ້. ການຕັ້ງຄ່ານີ້ບໍ່ມີໃນ KiCad, "
"ມັນຈຶ່ງຖືກຍົກເວັ້ນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1936
#, c-format
msgid ""
"The CADSTAR template '%s' has the setting 'Automatic Repour' enabled. This "
"setting has no KiCad equivalent, so it has been ignored."
msgstr ""
"ເທມເພດ CADSTAR '%s' ມີການຕັ້ງຄ່າ 'Automatic Repour' ເປີດໄວ້. ການຕັ້ງຄ່ານີ້ບໍ່ມີໃນ KiCad, "
"ມັນຈຶ່ງຖືກຍົກເວັ້ນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1948
#, c-format
msgid ""
"The CADSTAR template '%s' has a non-zero value defined for the 'Sliver "
"Width' setting. There is no KiCad equivalent for this, so this setting was "
"ignored."
msgstr ""
"ເທມເພດ CADSTAR '%s' ມີການກຳນົດຄ່າທີ່ບໍ່ແມ່ນສູນສຳລັບ 'Sliver Width'. ບໍ່ມີສິ່ງທີ່ທຽບເທົ່າໃນ "
"KiCad, ການຕັ້ງຄ່ານີ້ຈຶ່ງຖືກຍົກເວັ້ນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:1958
#, c-format
msgid ""
"The CADSTAR template '%s' has different settings for 'Retain Poured Copper - "
"Disjoint' and 'Retain Poured Copper - Isolated'. KiCad does not distinguish "
"between these two settings. The setting for disjoint copper has been applied "
"as the minimum island area of the KiCad Zone."
msgstr ""
"ເທມເພດ CADSTAR '%s' ມີການຕັ້ງຄ່າທີ່ແຕກຕ່າງກັນລະຫວ່າງ 'Retain Poured Copper - "
"Disjoint' ແລະ 'Retain Poured Copper - Isolated'. KiCad "
"ບໍ່ແຍກຄວາມແຕກຕ່າງລະຫວ່າງສອງການຕັ້ງຄ່ານີ້. ການຕັ້ງຄ່າສຳລັບ disjoint copper "
"ຈະຖືກນຳໃຊ້ມາເປັນພື້ນທີ່ເກາະຕ່ຳສຸດ (minimum island area) ຂອງໂຊນ KiCad."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:2009
#, c-format
msgid ""
"The CADSTAR template '%s' has different settings for thermal relief in pads "
"and vias. KiCad only supports one single setting for both. The setting for "
"pads has been applied."
msgstr ""
"ເທມເພດ CADSTAR '%s' ມີການຕັ້ງຄ່າ thermal relief ແຍກລະຫວ່າງແພັດ ແລະ ວີອາ. KiCad "
"ຮອງຮັບສະເພາະການຕັ້ງຄ່າດຽວສຳລັບທັງສອງ. ຈະນຳໃຊ້ການຕັ້ງຄ່າຂອງແພັດແທນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:2026
#, c-format
msgid ""
"The CADSTAR template '%s' has thermal reliefs in the original design but the "
"spoke width (%.2f mm) is thinner than the minimum thickness of the zone "
"(%.2f mm). KiCad requires the minimum thickness of the zone to be preserved. "
"Therefore the minimum thickness has been applied as the new spoke width and "
"will be applied next time the zones are filled."
msgstr ""
"ເທມເພດ CADSTAR '%s' ມີ thermal reliefs ໃນການອອກແບບເດີມ ແຕ່ຄວາມກວ້າງຂອງຂາ (spoke "
"width) (%.2f ມມ) ນ້ອຍກວ່າຄວາມໜາຕ່ຳສຸດຂອງໂຊນ (%.2f ມມ). KiCad "
"ກຳນົດໃຫ້ຮັກສາຄວາມໜາຕ່ຳສຸດຂອງໂຊນໄວ້. ດັ່ງນັ້ນ, ຄວາມໜາຕ່ຳສຸດຈະຖືກນຳໃຊ້ມາເປັນຄວາມກວ້າງຂອງຂາໃໝ່ "
"ແລະ ຈະມີຜົນເມື່ອມີການຖົມໂຊນຄັ້ງຕໍ່ໄປ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:2072
#, c-format
msgid ""
"The CADSTAR layer '%s' is defined as a power plane layer. However no net "
"with such name exists. The layer has been loaded but no copper zone was "
"created."
msgstr ""
"ຊັ້ນ CADSTAR '%s' ຖືກກຳນົດວ່າເປັນຊັ້ນ power plane. ແຕ່ຢ່າງໃດກໍຕາມ ບໍ່ພົບເນັດທີ່ມີຊື່ນັ້ນ. "
"ຊັ້ນໄດ້ຖືກໂຫຼດມາແລ້ວ ແຕ່ບໍ່ໄດ້ສ້າງໂຊນທອງແດງ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:2167
msgid ""
"The CADSTAR design contains COPPER elements, which have no direct KiCad "
"equivalent. These have been imported as a KiCad Zone if solid or hatch "
"filled, or as a KiCad Track if the shape was an unfilled outline (open or "
"closed)."
msgstr ""
"ການອອກແບບ CADSTAR ມີອົງປະກອບ COPPER ເຊິ່ງບໍ່ມີໃນ KiCad ໂດຍກົງ. ສິ່ງເຫຼົ່ານີ້ຈະຖືກນຳເຂົ້າເປັນໂຊນ "
"(Zone) KiCad ຖ້າມັນເປັນການຖົມແບບ solid ຫຼື hatch, ຫຼື ນຳເຂົ້າເປັນເສັ້ນລາຍປຣິນ (Track) "
"KiCad ຖ້າມັນເປັນພຽງແຕ່ເສັ້ນຂອບທີ່ບໍ່ມີການຖົມ (ທັງແບບເປີດ ຫຼື ປິດ)."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:2269
#, c-format
msgid ""
"The net '%s' references component ID '%s' which does not exist. This has "
"been ignored."
msgstr "ເນັດ '%s' ອ້າງອີງເຖິງ ID ອຸປະກອນ '%s' ເຊິ່ງບໍ່ມີຢູ່. ມັນຖືກຍົກເວັ້ນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:2275
#, c-format
msgid ""
"The net '%s' references non-existent pad index '%d' in component '%s'. This "
"has been ignored."
msgstr "ເນັດ '%s' ອ້າງອີງເຖິງດັດຊະນີແພັດ '%d' ທີ່ບໍ່ມີຢູ່ ໃນອຸປະກອນ '%s'. ມັນຖືກຍົກເວັ້ນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:2474
msgid "Text Variables could not be set as there is no project loaded."
msgstr "ບໍ່ສາມາດຕັ້ງຄ່າຕົວປ່ຽນຂໍ້ຄວາມ (Text Variables) ໄດ້ ເພາະຍັງບໍ່ໄດ້ໂຫຼດໂຄງການ (project)."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:2558
msgid ""
"The CADSTAR design contains teardrops. This importer does not yet support "
"them, so the teardrops in the design have been ignored."
msgstr ""
"ການອອກແບບ CADSTAR ນີ້ມີເທຍດຣັອບ (teardrops). ຕົວນຳເຂົ້ານີ້ຍັງບໍ່ຮອງຮັບ, "
"ເທຍດຣັອບໃນການອອກແບບຈຶ່ງຖືກຍົກເວັ້ນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:2588
#, c-format
msgid ""
"The CADSTAR via code '%s' has different shape from a circle defined. KiCad "
"only supports circular vias so this via type has been changed to be a via "
"with circular shape of %.2f mm diameter."
msgstr ""
"ລະຫັດວີອາ CADSTAR '%s' ມີຮູບຊົງທີ່ບໍ່ແມ່ນວົງມົນ. KiCad ຮອງຮັບສະເພາະວີອາຮູບວົງມົນເທົ່ານັ້ນ, "
"ດັ່ງນັ້ນວີອາປະເພດນີ້ຈຶ່ງຖືກປ່ຽນເປັນວົງມົນທີ່ມີເສັ້ນຜ່າໃຈກາງ %.2f ມມ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:3563
#, c-format
msgid ""
"The CADSTAR Hatching code '%s' has %d hatches defined. KiCad only supports 2 "
"hatches (crosshatching) 90 degrees apart. The imported hatching is "
"crosshatched."
msgstr ""
"ລະຫັດການຖົມ (Hatching) CADSTAR '%s' ມີການຖົມ %d ແບບ. KiCad ຮອງຮັບສະເພາະການຖົມ 2 "
"ແບບ (crosshatching) ທີ່ຫ່າງກັນ 90 ອົງສາ. ການຖົມທີ່ນຳເຂົ້າມາຈະຖືກປ່ຽນເປັນແບບ crosshatched."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:3573
#, c-format
msgid ""
"The CADSTAR Hatching code '%s' has different line widths for each hatch. "
"KiCad only supports one width for the hatching. The imported hatching uses "
"the width defined in the first hatch definition, i.e. %.2f mm."
msgstr ""
"ລະຫັດການຖົມ CADSTAR '%s' ມີຄວາມກວ້າງເສັ້ນທີ່ແຕກຕ່າງກັນໃນແຕ່ລະການຖົມ. KiCad "
"ຮອງຮັບສະເພາະຄວາມກວ້າງດຽວສຳລັບການຖົມ. ການຖົມທີ່ນຳເຂົ້າມາຈະໃຊ້ຄວາມກວ້າງຈາກການກຳນົດອັນທຳອິດ, "
"ຄື %.2f ມມ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:3585
#, c-format
msgid ""
"The CADSTAR Hatching code '%s' has different step sizes for each hatch. "
"KiCad only supports one step size for the hatching. The imported hatching "
"uses the step size defined in the first hatching definition, i.e. %.2f mm."
msgstr ""
"ລະຫັດການຖົມ CADSTAR '%s' ມີຂະໜາດໄລຍະຫ່າງ (step sizes) ທີ່ແຕກຕ່າງກັນໃນແຕ່ລະການຖົມ. "
"KiCad ຮອງຮັບສະເພາະໄລຍະຫ່າງດຽວ. ການຖົມທີ່ນຳເຂົ້າມາຈະໃຊ້ໄລຍະຫ່າງຈາກການກຳນົດອັນທຳອິດ, ຄື "
"%.2f ມມ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:3598
#, c-format
msgid ""
"The hatches in CADSTAR Hatching code '%s' have an angle  difference of %.1f "
"degrees. KiCad only supports hatching 90 degrees apart.  The imported "
"hatching has two hatches 90 degrees apart, oriented %.1f degrees from "
"horizontal."
msgstr ""
"ການຖົມໃນລະຫັດ CADSTAR '%s' ມີມຸມທີ່ແຕກຕ່າງກັນ %.1f ອົງສາ. KiCad "
"ຮອງຮັບສະເພາະການຖົມທີ່ຫ່າງກັນ 90 ອົງສາ. ການຖົມທີ່ນຳເຂົ້າມາຈະມີ 2 ການຖົມທີ່ຫ່າງກັນ 90 ອົງສາ "
"ໂດຍວາງມຸມ %.1f ອົງສາຈາກແນວນອນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:3668
#, c-format
msgid ""
"Dimension ID %s uses a type of unit that is not supported in KiCad. "
"Millimeters were applied instead."
msgstr "ID ການບອກຂະໜາດ %s ໃຊ້ປະເພດຫົວໜ່ວຍທີ່ KiCad ບໍ່ຮອງຮັບ. ຈະໃຊ້ຫົວໜ່ວຍມິນລິແມັດແທນ."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:3946
msgid ""
"The CADSTAR design contains nets with a 'Net Class' assigned. KiCad does not "
"have an equivalent to CADSTAR's Net Class so these elements were not "
"imported. Note: KiCad's version of 'Net Class' is closer to CADSTAR's 'Net "
"Route Code' (which has been imported for all nets)."
msgstr ""
"ການອອກແບບ CADSTAR ມີເນັດທີ່ຖືກກຳນົດ 'Net Class' ໄວ້. KiCad ບໍ່ມີສິ່ງທີ່ທຽບເທົ່າກັບ Net Class "
"ຂອງ CADSTAR ດັ່ງນັ້ນອົງປະກອບເຫຼົ່ານີ້ຈຶ່ງບໍ່ໄດ້ຖືກນຳເຂົ້າ. ໝາຍເຫດ: 'Net Class' ຂອງ KiCad "
"ຈະໃກ້ຄຽງກັບ 'Net Route Code' ຂອງ CADSTAR ຫຼາຍກວ່າ (ເຊິ່ງໄດ້ຖືກນຳເຂົ້າສຳລັບທຸກເນັດແລ້ວ)."

#: pcbnew/pcb_io/cadstar/cadstar_pcb_archive_loader.cpp:3955
msgid ""
"The CADSTAR design contains nets with a 'Spacing Class' assigned. KiCad does "
"not have an equivalent to CADSTAR's Spacing Class so these elements were not "
"imported. Please review the design rules as copper pours may be affected by "
"this."
msgstr ""
"ການອອກແບບ CADSTAR ມີເນັດທີ່ຖືກກຳນົດ 'Spacing Class' ໄວ້. KiCad ບໍ່ມີສິ່ງທີ່ທຽບເທົ່າກັບ "
"Spacing Class ຂອງ CADSTAR ດັ່ງນັ້ນອົງປະກອບເຫຼົ່ານີ້ຈຶ່ງບໍ່ໄດ້ຖືກນຳເຂົ້າ. "
"ກະລຸນາກວດສອບກົດການອອກແບບ ເພາະການຖົມທອງແດງອາດຈະໄດ້ຮັບຜົນກະທົບຈາກສິ່ງນີ້."

#: pcbnew/pcb_io/cadstar/pcb_io_cadstar_archive.h:37
msgid "CADSTAR PCB Archive files"
msgstr "ໄຟລ໌ CADSTAR PCB Archive"

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1070
#, c-format
msgid "DipTrace parse error at offset 0x%06zX: %s"
msgstr "ຂໍ້ຜິດພາດໃນການວິເຄາະ DipTrace ທີ່ offset 0x%06zX: %s"

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1156
#, c-format
msgid "DipTrace: invalid magic length %u (expected 7 or 11)"
msgstr "DipTrace: ຄວາມຍາວ magic ບໍ່ຖືກຕ້ອງ %u (ຄາດຫວັງ 7 ຫຼື 11)"

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1164
msgid "DipTrace: not a valid .dip board file (bad magic)"
msgstr "DipTrace: ບໍ່ແມ່ນໄຟລ໌ບອດ .dip ທີ່ຖືກຕ້ອງ (bad magic)"

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1181
msgid "DipTrace: invalid legacy board version suffix"
msgstr "DipTrace: ຄຳລົງທ້າຍເວີຊັນບອດລຸ້ນເກົ່າບໍ່ຖືກຕ້ອງ"

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1224
#, c-format
msgid "DipTrace import: invalid outline vertex count %d."
msgstr "ນຳເຂົ້າ DipTrace: ຈຳນວນຈຸດຍອດຂອບ (outline vertex) ບໍ່ຖືກຕ້ອງ %d."

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1264
#, c-format
msgid "DipTrace import: invalid layer count %d."
msgstr "ນຳເຂົ້າ DipTrace: ຈຳນວນຊັ້ນ (layer) ບໍ່ຖືກຕ້ອງ %d."

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1363
#, c-format
msgid "DipTrace: invalid pattern-name group count %d at offset 0x%06zX"
msgstr "DipTrace: ຈຳນວນກຸ່ມ pattern-name ບໍ່ຖືກຕ້ອງ %d ທີ່ offset 0x%06zX"

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1376
#, c-format
msgid "DipTrace: invalid pattern-name block count %d"
msgstr "DipTrace: ຈຳນວນບລັອກ pattern-name ບໍ່ຖືກຕ້ອງ %d"

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1393
#, c-format
msgid "DipTrace: invalid pattern-style group count %d at offset 0x%06zX"
msgstr "DipTrace: ຈຳນວນກຸ່ມ pattern-style ບໍ່ຖືກຕ້ອງ %d ທີ່ offset 0x%06zX"

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1415
#, c-format
msgid "DipTrace: invalid pattern-style entry count %d"
msgstr "DipTrace: ຈຳນວນຂໍ້ມູນ pattern-style ບໍ່ຖືກຕ້ອງ %d"

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1435
#, c-format
msgid "DipTrace: invalid implicit pattern-style entry count %d"
msgstr "DipTrace: ຈຳນວນຂໍ້ມູນ implicit pattern-style ບໍ່ຖືກຕ້ອງ %d"

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1518
#, c-format
msgid "DipTrace: invalid design-rule extra count %d"
msgstr "DipTrace: ຈຳນວນ design-rule extra ບໍ່ຖືກຕ້ອງ %d"

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1546
#, c-format
msgid "DipTrace: invalid ruleset transition marker at 0x%06zX"
msgstr "DipTrace: ເຄື່ອງໝາຍປ່ຽນ ruleset ບໍ່ຖືກຕ້ອງທີ່ 0x%06zX"

#: pcbnew/pcb_io/diptrace/diptrace_pcb_parser.cpp:1864
msgid "DipTrace: no validated component boundaries found"
msgstr "DipTrace: ບໍ່ພົບຂອບເຂດອຸປະກອນທີ່ຜ່ານການກວດສອບ"

