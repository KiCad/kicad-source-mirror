#: eeschema/sim/kibis/kibis.cpp:1805 eeschema/sim/kibis/kibis.cpp:1852
msgid "Number of cycles should be greater than 0."
msgstr "ຈຳນວນຮອບ (cycles) ຄວນຫຼາຍກວ່າ 0."

#: eeschema/sim/kibis/kibis.cpp:1811 eeschema/sim/kibis/kibis.cpp:1858
msgid "ON time should be greater than 0."
msgstr "ເວລາເປີດ (ON time) ຄວນຫຼາຍກວ່າ 0."

#: eeschema/sim/kibis/kibis.cpp:1817 eeschema/sim/kibis/kibis.cpp:1864
msgid "OFF time should be greater than 0."
msgstr "ເວລາປິດ (OFF time) ຄວນຫຼາຍກວ່າ 0."

#: eeschema/sim/kibis/kibis.cpp:1825
msgid "Rising edge is longer than on time."
msgstr "ຂອບຂາຂຶ້ນ (Rising edge) ຍາວກວ່າເວລາເປີດ."

#: eeschema/sim/kibis/kibis.cpp:1834
msgid "Falling edge is longer than off time."
msgstr "ຂອບຂາລົງ (Falling edge) ຍາວກວ່າເວລາປິດ."

#: eeschema/sim/kibis/kibis.cpp:1872
msgid "Rising edge is longer than ON time."
msgstr "ຂອບຂາຂຶ້ນຍາວກວ່າເວລາເປີດ (ON time)."

#: eeschema/sim/kibis/kibis.cpp:1880
msgid "Falling edge is longer than OFF time."
msgstr "ຂອບຂາລົງຍາວກວ່າເວລາປິດ (OFF time)."

#: eeschema/sim/kibis/kibis.cpp:1895 eeschema/sim/kibis/kibis.cpp:1927
msgid "Bitrate should be greater than 0."
msgstr "ອັດຕາບິດ (Bitrate) ຄວນຫຼາຍກວ່າ 0."

#: eeschema/sim/kibis/kibis.cpp:1901 eeschema/sim/kibis/kibis.cpp:1933
msgid "Number of bits should be greater than 0."
msgstr "ຈຳນວນບິດຄວນຫຼາຍກວ່າ 0."

#: eeschema/sim/kibis/kibis.cpp:1913
msgid "Bitrate is too high for rising / falling edges"
msgstr "ອັດຕາບິດສູງເກີນໄປສຳລັບຂອບຂາຂຶ້ນ / ຂາລົງ"

#: eeschema/sim/kibis/kibis.cpp:1941
