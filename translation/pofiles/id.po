#: common/env_vars.cpp:111
msgid ""
"The base path of locally installed system footprint libraries (.pretty "
"folders)."
msgstr ""
"Jalur dasar pustaka footprint sistem yang dipasang secara lokal (direktori ."
"pretty)."

#: common/env_vars.cpp:114
msgid "The base path of system footprint 3D shapes (.3Dshapes folders)."
msgstr "Jalur dasar bentuk 3D footprint sistem (direktori .3Dshapes)."

#: common/env_vars.cpp:117
msgid "The base path of the locally installed symbol libraries."
msgstr "Path dasar untuk pustaka simbol yang dipasang secara lokal."

#: common/env_vars.cpp:120
msgid "A directory containing project templates installed with KiCad."
msgstr "Direktori yang berisi templat proyek yang dipasang bersama KiCad."

#: common/env_vars.cpp:123
msgid ""
"Optional. Can be defined if you want to create your own project templates "
"folder."
msgstr ""
"Opsional. Dapat ditentukan jika Anda ingin membuat direktori templat proyek "
"sendiri."

#: common/env_vars.cpp:126
msgid ""
"A directory containing 3rd party plugins, libraries and other downloadable "
"content."
msgstr ""
"Direktori yang berisi plugin, pustaka, dan konten pihak ketiga yang dapat "
"diunduh."

#: common/env_vars.cpp:129
msgid ""
"Internally defined by KiCad (cannot be edited) and is set to the absolute "
"path of the currently loaded project file.  This environment variable can be "
"used to define files and paths relative to the currently loaded project.  "
"For instance, ${KIPRJMOD}/libs/footprints.pretty can be defined as a folder "
"containing a project specific footprint library named footprints.pretty."
msgstr ""
"Didefinisikan secara internal oleh KiCad (tidak dapat disunting) dan diatur "
"ke path absolut dari berkas proyek yang sedang dimuat. Variabel lingkungan "
"ini dapat digunakan untuk mendefinisikan berkas dan path relatif proyek yang "
"sedang dimuat.  Misalnya, ${KIPRJMOD}/libs/footprints.pretty dapat "
"didefinisikan sebagai sebuah direktori yang berisi pustaka footprint khusus "
"proyek bernama footprints.pretty."

#: common/env_vars.cpp:135
msgid "A directory containing system-wide scripts installed with KiCad."
msgstr "Direktori yang berisi skrip sistem yang dipasang bersama KiCad."

#: common/env_vars.cpp:138
msgid "A directory containing user-specific scripts installed with KiCad."
msgstr ""
"Direktori yang berisi skrip khusus pengguna yang dipasang bersama KiCad."

