#: pcbnew/dialogs/dialog_pns_settings_base.cpp:52
msgid ""
"When disabled, vias are treated as un-movable objects and hugged instead of "
"shoved."
msgstr ""
"Jika dinonaktifkan, via diperlakukan sebagai objek yang tidak dapat "
"dipindahkan dan dikelilingi alih-alih didorong."

