msgstr "Lompati hambatan"

#: pcbnew/dialogs/dialog_pns_settings_base.cpp:57
msgid ""
"When enabled, the router tries to move colliding tracks behind solid "
"obstacles (e.g. pads) instead of \"reflecting\" back the collision"
msgstr ""
