#: pcb_calculator/calculator_panels/panel_electrical_spacing_iec60664_base.cpp:179
msgid "Pollution Degree:"
msgstr "Derajat Polusi:"

#: pcb_calculator/calculator_panels/panel_electrical_spacing_iec60664_base.cpp:181
msgid ""
"PD1: No pollution or only dry, non-conductive pollution occurs\n"
"\n"
"PD2: Only non-conductive pollution occurs . Condensation may occur.\n"
"\n"
"PD3: Conductive pollution occurs, or non-conductive pollution occurs which "
"becomes conductive due to expected condensation.\n"
"\n"
"PD4: Continuous conductivity occurs due to conductive dust, rain, ..."
msgstr ""
"PD1: Tidak ada polusi atau hanya polusi kering, non-konduktif\n"
"\n"
"PD2: Hanya polusi non-konduktif. Kondensasi mungkin terjadi.\n"
"\n"
"PD3: Polusi konduktif terjadi, atau polusi non-konduktif yang menjadi "
"konduktif akibat kondensasi yang diperkirakan.\n"
"\n"
"PD4: Konduktivitas terus-menerus akibat debu konduktif, hujan, ..."

