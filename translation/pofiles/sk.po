#: pcb_calculator/calculator_panels/panel_transline.cpp:65
msgid ""
"Enable solder resist / LPI overlay correction.  Affects εeff, Z0, and "
"dielectric loss for microstrip, coupled microstrip, CPW, and CBCPW."
msgstr ""
"Povoliť korekciu spájkovacej masky / prekrytia LPI.  Ovplyvňuje εeff, Z0 a "
"dielektrické straty pre mikropáskové vedenie, prepojené mikropáskové "
"vedenie, CPW a CBCPW."

#: pcb_calculator/calculator_panels/panel_transline.cpp:69
msgid ""
"Cured mask thickness.  Typical LPI is 15-30 um; set to 0 or uncheck to "
"disable."
msgstr ""
"Hrúbka vytvrdenej masky.  Typický LPI je 15 – 30 µm; nastaviť na 0 alebo "
"zrušiť začiarknutie pre deaktiváciu."

#: pcb_calculator/calculator_panels/panel_transline.cpp:74
msgid ""
"Mask relative permittivity.  Default 3.5 for standard green LPI.  Range "
"3.3-3.8 for typical resins."
msgstr ""
"Relatívna permitivita masky.  Predvolená hodnota 3,5 pre štandardný zelený "
"LPI.  Rozsah 3,3 – 3,8 pre typické živice."

#: pcb_calculator/calculator_panels/panel_transline.cpp:79
msgid "Mask loss tangent.  Default 0.025 for LPI."
msgstr "Tangens straty na maske.  Predvolená hodnota pre LPI je 0,025."

#: pcb_calculator/calculator_panels/panel_transline.cpp:83
