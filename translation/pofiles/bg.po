msgstr "Порт %s няма връзки."

#: eeschema/sch_io/altium/sch_io_altium.cpp:4401
#, c-format
msgid "Embedded file %s not found in storage."
msgstr "Вграденият файл %s не е намерен в хранилището."

#: eeschema/sch_io/altium/sch_io_altium.cpp:4418
#: eeschema/sch_io/altium/sch_io_altium.cpp:4437
