"        <td></td>\n"
"        <td>&nbsp;<br><samp>Price: $25.00</samp></td>\n"
"    </tr>\n"
"    <tr>\n"
"        <td>&nbsp;<br><samp>\\@{x+y}</samp></td>\n"
"        <td></td>\n"
"        <td>&nbsp;<br><samp>@{x+y}</samp> (not evaluated)</td>\n"
