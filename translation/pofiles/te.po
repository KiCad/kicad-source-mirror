"        <td>&nbsp;<br><samp>{net1 net2 ...}</samp></td>\n"
"        <td></td>\n"
"        <td>&nbsp;<br><samp>net1, net2, ...</samp></td>\n"
"    </tr>\n"
"    <tr>\n"
"        <td>&nbsp;<br><samp>{SCL SDA}</samp></td>\n"
"        <td></td>\n"
"        <td>&nbsp;<br><samp>SCL, SDA</samp></td>\n"
"    </tr>\n"
"    <tr>\n"
"        <td><br></td>\n"
"    </tr>\n"
