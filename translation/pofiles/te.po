"        <td>&nbsp;<br><samp>USB1{D+ D-}</samp></td>\n"
"        <td></td>\n"
"        <td>&nbsp;<br><samp>USB1.D+, USB1.D-</samp></td>\n"
"    </tr>\n"
"    <tr>\n"
"        <td><br></td>\n"
"    </tr>\n"
