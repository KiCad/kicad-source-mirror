"&nbsp;&nbsp;&nbsp;</th>\n"
"        <th>Resultant Nets</th>\n"
"    </tr>\n"
"    <tr>\n"
"        <td>&nbsp;<br><samp>prefix[m..n]</samp></td>\n"
"        <td></td>\n"
"        <td>&nbsp;<br><samp>prefixm to prefixn</samp></td>\n"
"    </tr>\n"
"    <tr>\n"
"        <td>&nbsp;<br><samp>D[0..7]</samp></td>\n"
"        <td></td>\n"
"        <td>&nbsp;<br><samp>D0, D1, D2, D3, D4, D5, D6, D7</samp></td>\n"
"    </tr>\n"
"    <tr>\n"
"        <td><br></td>\n"
"    </tr>\n"
