#: common/git/kicad_git_errors.cpp:40
msgid "Invalid repository."
msgstr "చెల్లని రిపాజిటరీ."

#: common/git/kicad_git_errors.cpp:41
msgid "Failed to commit changes."
msgstr "మార్పులు కమిట్ చేయడం విఫలమైంది."

#: common/git/kicad_git_errors.cpp:42
msgid "Failed to merge branches."
msgstr "బ్రాంచ్‌లను విలీనం చేయడం విఫలమైంది."

#: common/git/kicad_git_errors.cpp:45
msgid "Failed to clone repository."
msgstr "రిపాజిటరీని క్లోన్ చేయడం విఫలమైంది."

#: common/git/kicad_git_errors.cpp:46
msgid "Remote repository not found."
msgstr "రిమోట్ రిపోజిటరీ కనుగొనబడలేదు."

#: common/git/kicad_git_errors.cpp:47
msgid "Authentication failed for remote repository."
msgstr "రిమోట్ రిపాజిటరీ కోసం ప్రమాణీకరణ విఫలమైంది."

#: common/git/kicad_git_errors.cpp:50
msgid "Branch not found."
msgstr "శాఖ కనుగొనబడలేదు."

#: common/git/kicad_git_errors.cpp:51
msgid "Failed to create branch."
msgstr "బ్రాంచ్ సృష్టించడం విఫలమైంది."

#: common/git/kicad_git_errors.cpp:52
msgid "Failed to delete branch."
msgstr "బ్రాంచ్ తొలగించడం విఫలమైంది."

#: common/git/kicad_git_errors.cpp:55 common/git/libgit_backend.cpp:982
msgid "Failed to perform checkout operation."
msgstr "చెకౌట్ ఆపరేషన్ చేయడం విఫలమైంది."

#: common/git/kicad_git_errors.cpp:56
msgid "File not found during checkout operation."
msgstr "చెక్‌అవుట్ ఆపరేషన్ సమయంలో ఫైల్ కనుగొనబడలేదు."

#: common/git/kicad_git_errors.cpp:59
msgid "Merge conflict encountered."
msgstr "విలీన వైరుధ్యం ఏర్పడింది."

#: common/git/kicad_git_errors.cpp:60
msgid "Rebase conflict encountered."
msgstr "రీబేస్ వైరుధ్యం ఏర్పడింది."

#: common/git/kicad_git_errors.cpp:63
msgid "Failed to pull changes from remote repository."
msgstr "రిమోట్ రిపాజిటరీ నుండి మార్పులు పుల్ చేయడం విఫలమైంది."

#: common/git/kicad_git_errors.cpp:64
msgid "Failed to push changes to remote repository."
msgstr "రిమోట్ రిపాజిటరీకి మార్పులు పుష్ చేయడం విఫలమైంది."

#: common/git/kicad_git_errors.cpp:65
msgid "No upstream branch configured."
msgstr "అప్‌స్ట్రీమ్ శాఖ కాన్ఫిగర్ చేయబడలేదు."

#: common/git/kicad_git_errors.cpp:67
msgid "Failed to establish connection with remote repository."
msgstr "రిమోట్ రిపాజిటరీతో కనెక్షన్ ఏర్పాటు చేయడం విఫలమైంది."

