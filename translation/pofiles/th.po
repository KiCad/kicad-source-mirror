"&nbsp;&nbsp;&nbsp;</th>\n"
"        <th>เน็ตที่ได้</th>\n"
"    </tr>\n"
"    <tr>\n"
"        <td>&nbsp;<br><samp>prefix[m..n]</samp></td>\n"
