msgid "(PTH pad hole leaves no copper)"
msgstr "(รูเจาะแพ็ด PTH ไม่มีทองแดงเหลือ)"

#: pcbnew/pad.cpp:2993
msgid "(PTH pad hole not fully inside copper)"
msgstr "(รูเจาะแพ็ด PTH ไม่อยู่ภายในทองแดงทั้งหมด)"

