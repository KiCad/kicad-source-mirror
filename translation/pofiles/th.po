msgid "('testpoint' pads are normally plated)"
msgstr "(แพ็ด 'testpoint' โดยปกติชุบ)"

#: pcbnew/pad.cpp:2855
msgid "('heatsink' pads are normally plated)"
msgstr "(แพ็ด 'heatsink' โดยปกติชุบ)"

