#: pcb_calculator/calculator_panels/panel_electrical_spacing_iec60664_base.cpp:134
msgid "Transient overvoltage:"
msgstr "Sobretensió transitòria:"

#: pcb_calculator/calculator_panels/panel_electrical_spacing_iec60664_base.cpp:136
msgid ""
"Transient overvoltages due to:\n"
"\n"
"- Atmospheric disturbances transmitted by the mains supply (eg: a lightning "
"strike)\n"
"- Switching loads in the main supplys\n"
"- External circuits\n"
"- Internal generation\n"
"\n"
"Events that last for a few milliseconds or less."
msgstr ""
"Sobretensions transitòries degudes a:\n"
"\n"
"- Pertorbacions atmosfèriques transmeses per la xarxa elèctrica (p. ex.: un "
"llamp)\n"
"- Commutació de càrregues a la xarxa elèctrica principal\n"
"- Circuits externs\n"
"- Generació interna\n"
"\n"
"Esdeveniments que duren uns pocs mil·lisegons o menys."

#: pcb_calculator/calculator_panels/panel_electrical_spacing_iec60664_base.cpp:149
msgid "Recurring peak voltage:"
msgstr "Tensió de pic recurrent:"

#: pcb_calculator/calculator_panels/panel_electrical_spacing_iec60664_base.cpp:151
msgid ""
"- Steady-state voltage value\n"
"- Temporary overvoltage\n"
"- Recurring peak voltage\n"
"\n"
"Events of relatively long duration."
msgstr ""
"- Valor de tensió en estat estacionari\n"
"- Sobretensió temporal\n"
"- Tensió de pic recurrent\n"
"\n"
"Esdeveniments de durada relativament llarga."

#: pcb_calculator/calculator_panels/panel_electrical_spacing_iec60664_base.cpp:164
msgid "Type of insulation:"
msgstr "Tipus d'aïllament:"

#: pcb_calculator/calculator_panels/panel_electrical_spacing_iec60664_base.cpp:166
msgid ""
"Functional: insulation is necessary only for the functioning of the "
"equipment\n"
"\n"
"Basic: Insulation of hazardous-live parts.\n"
"\n"
"Reinforced: Single insulation that provides a degree of protection "
"equivalent to a double insulation. ( which is two separate basic "
"insulations, in case one of them fails  )."
msgstr ""
"Funcional: l'aïllament és necessari únicament per al funcionament de "
"l'equip\n"
"\n"
"Bàsic: aïllament de parts perilloses sota tensió.\n"
"\n"
"Reforçat: aïllament senzill que proporciona un grau de protecció equivalent "
"a un doble aïllament."

