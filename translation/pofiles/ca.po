msgid "Material group:"
msgstr "Grup de material:"

#: pcb_calculator/calculator_panels/panel_electrical_spacing_iec60664_base.cpp:196
msgid ""
"Materials with a high comparative tracking index (CTI) are better at "
"providing isolation.\n"
"\n"
"Material group I: 600 <= CTI\n"
"Material group II: 400 <= CTI < 600\n"
"Material group IIIa: 175 <= CTI < 400\n"
"Material group IIIb: 100 <= CTI < 175"
msgstr ""
"Els materials amb un índex de seguiment comparatiu (CTI) alt són millors per "
"proporcionar aïllament.\n"
"\n"
"Grup de material I: 600 <= CTI\n"
"Grup de material II: 400 <= CTI < 600\n"
"Grup de material IIIa: 175 <= CTI < 400\n"
"Grup de material IIIb: 100 <= CTI < 175"

