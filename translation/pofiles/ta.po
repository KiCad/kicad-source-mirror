msgid "Functional"
msgstr "செயல்பாடு"

#: pcb_calculator/calculator_panels/panel_electrical_spacing_iec60664_base.cpp:170
msgid "Basic"
msgstr "அடிப்படை"

#: pcb_calculator/calculator_panels/panel_electrical_spacing_iec60664_base.cpp:170
