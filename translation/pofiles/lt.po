msgstr "Korpusas '%s' nerastas '%s'."

#: pcbnew/pcb_io/altium/pcb_io_altium_designer.h:54
msgid "Altium Designer PCB files"
msgstr "Altium Designer PCB failai"

#: pcbnew/pcb_io/altium/pcb_io_altium_designer.h:59
