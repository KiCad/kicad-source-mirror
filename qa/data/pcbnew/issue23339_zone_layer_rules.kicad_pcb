		)
		(min_thickness 0.25)
		(filled_areas_thickness no)
		(fill yes
			(thermal_gap 0.5)
			(thermal_bridge_width 0.5)
		)
		(polygon
			(pts
				(xy 92 87) (xy 120 87) (xy 120 113) (xy 92 113)
			)
		)
	)
	(zone
		(net 2)
		(net_name "LV_NET")
		(layers "F.Cu" "In1.Cu")
		(uuid "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb")
		(hatch edge 0.5)
