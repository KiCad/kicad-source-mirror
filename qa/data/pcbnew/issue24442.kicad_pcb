		(layer "F.SilkS")
		(uuid "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa02")
		(effects
			(font
				(size 1.5 1.5)
				(thickness 0.3)
			)
		)
	)
	(gr_text "${DRC_WARNING this_is_warning} trailing"
