		(uuid "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa03")
		(effects
			(font
				(size 1.5 1.5)
				(thickness 0.3)
			)
		)
	)
	(gr_text "prefix ${DRC_WARNING embedded_warning} suffix"
