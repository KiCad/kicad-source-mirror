E3 MTG_HOLE_TYPE 1500  500 0.000 U M 0 -1 0 -1 0
E4 MTG_HOLE_TYPE 1500 1500 0.000 U M 0 -1 0 -1 0

X1 SQ_PIN1_TYPE 3000  500 0.000 U N 0 -1 0 -1 0
X2 SQ_PIN1_TYPE 3000 1500 0.000 U M 0 -1 0 -1 0

