        "BeagleBone_Black_RevC": {
            "formatVersion": "17.2",
            "boardFile": "BeagleBone_Black_RevC.brd",
            "blocks": [
                {
                    "type": "0x1C",
                    "offset": "0x0007c420",
                    "comment": "Padstack 120X040SLOT, slotted PTH pad",
                    "extraBlockTest": true
                }
            ],
            "boardExpectations": [
                {
                    "skip": true,
                    "testName": "DP_Netclasses",
                    "comment": "Verify that diff pair match groups in BeagleBone Black produce netclasses with the DP_ prefix and contain exactly 2 nets each.",
                    "type": "netclass",
                    "name": "DP_HDMI_TXC",
                    "netCount": 2
                },
                {
                    "type": "netclass",
                    "name": "DP_USB0",
                    "netCount": 2
                },
                {
                    "comment": "Verify that match groups with more than 2 nets (DDR byte lanes, address buses) produce netclasses with the MG_ prefix.",
                    "type": "netclass",
                    "name": "MG_DDR_DQ0",
                    "netCount": 11
                },
                {
                    "type": "netclass",
                    "name": "MG_DDR_ADD",
                    "netCount": 26
                },
                {
                    "comment": "Verify there are 4 match groups",
                    "type": "netclass",
                    "name": "MG_*",
                    "count": 4
                },
                {
                    "comment": "BB Black has 5 constraint sets, all with 4.0 mil (101600 nm) clearance",
                    "type": "netclass",
                    "name": [
                        "Allegro_Default",
                        "PWR",
                        "BGA",
                        "90_OHM_DIFF",
                        "100OHM_DIFF"
                    ],
                    "clearance": "4 mil"
                },
                {
                    "type": "netclass",
                    "name": "PWR",
                    "trackWidth": "15 mil"
                },
                {
                    "comment": "The default netclass should have 4.75 mil tracks and match something",
                    "type": "netclass",
                    "name": "Allegro_Default",
                    "trackWidth": "4.75 mil",
                    "netCount": {
                        "min": 1
                    }
                },
                {
                    "comment": "90_OHM_DIFF: f[1]=450, f[4]=400, f[7]=650 (divisor=100, scale=254 nm/unit)",
                    "type": "netclass",
                    "name": "90_OHM_DIFF",
                    "trackWidth": "4.5 mil",
                    "clearance": "4 mil",
                    "dpGap": "6.5 mil",
                    "dpWidth": "4.5 mil"
                },
                {
                    "comment": "100_OHM_DIFF: f[1]=375, f[4]=400, f[7]=725 (divisor=100, scale=254 nm/unit)",
                    "type": "netclass",
                    "name": "100OHM_DIFF",
                    "trackWidth": "3.75 mil",
                    "clearance": "4 mil",
                    "dpGap": "7.25 mil",
                    "dpWidth": "3.75 mil"
                },
                {
                    "comment": "// BGA: f[1]=300, f[7]=300 (divisor=100, 300*254=76200 nm)",
                    "type": "netclass",
                    "name": "BGA",
                    "dpGap": "3 mil",
                    "dpWidth": "3 mil"
                },
                {
                    "comment": "Simple via count",
                    "type": "item",
                    "itemType": "via",
                    "count": {
                        "min": 100
                    }
                },
                {
                    "type": "item",
                    "itemType": "track",
                    "expr": "A.width > 10 mil",
                    "count": {
                        "min": 1
                    }
                }
            ]
        },
